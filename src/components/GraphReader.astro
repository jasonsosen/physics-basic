---
// Week 09: x-t / v-t グラフ (同步联动版)
---

<div class="graph-trainer" data-graph-trainer>
  <div class="trainer-header">
    <h3>📈 グラフの読み取り</h3>
    <p class="subtitle">傾き・面積を読み取ろう！</p>
  </div>

  <!-- 小车动画 + 双图同步 -->
  <div class="sim-section">
    <div class="car-track">
      <div class="track-line"></div>
      <div class="car" data-car>🚗</div>
      <div class="position-markers">
        <span style="left:0%">0</span>
        <span style="left:25%">10</span>
        <span style="left:50%">20</span>
        <span style="left:75%">30</span>
        <span style="left:100%">40m</span>
      </div>
    </div>
    
    <div class="graphs-container">
      <div class="graph-panel">
        <div class="graph-label">x-t グラフ（傾き＝速度）</div>
        <canvas data-xt-canvas width="300" height="180"></canvas>
      </div>
      <div class="graph-panel">
        <div class="graph-label">v-t グラフ（面積＝変位）</div>
        <canvas data-vt-canvas width="300" height="180"></canvas>
      </div>
    </div>
    
    <div class="playback-controls">
      <button class="play-btn" data-play>▶️ 再生</button>
      <button class="reset-btn" data-reset>⏹️ リセット</button>
      <div class="time-display">t = <span data-time>0</span> s</div>
    </div>
  </div>

  <!-- 关键概念 -->
  <div class="concepts-row">
    <div class="concept-card">
      <span class="concept-icon">📐</span>
      <div class="concept-text">
        <strong>x-tグラフの傾き</strong><br>
        = 速度 v
      </div>
    </div>
    <div class="concept-card">
      <span class="concept-icon">📊</span>
      <div class="concept-text">
        <strong>v-tグラフの傾き</strong><br>
        = 加速度 a
      </div>
    </div>
    <div class="concept-card">
      <span class="concept-icon">🔲</span>
      <div class="concept-text">
        <strong>v-tグラフの面積</strong><br>
        = 変位 x
      </div>
    </div>
  </div>

  <!-- 练习题 -->
  <div class="practice-section">
    <h4>📝 グラフから読み取る練習</h4>
    
    <div class="quiz-grid">
      <div class="quiz-item" data-quiz="1">
        <span>① t = 0〜10 s の速度は？</span>
        <input type="number" data-answer placeholder="?">
        <span>m/s</span>
        <button data-check data-correct="3">確認</button>
        <span class="feedback" data-feedback></span>
      </div>
      
      <div class="quiz-item" data-quiz="2">
        <span>② t = 10〜15 s の速度は？</span>
        <input type="number" data-answer placeholder="?">
        <span>m/s</span>
        <button data-check data-correct="0">確認</button>
        <span class="feedback" data-feedback></span>
      </div>
      
      <div class="quiz-item" data-quiz="3">
        <span>③ t = 0〜10 s の加速度は？</span>
        <input type="number" data-answer placeholder="?" step="any">
        <span>m/s²</span>
        <button data-check data-correct="0">確認</button>
        <span class="feedback" data-feedback></span>
      </div>
      
      <div class="quiz-item" data-quiz="4">
        <span>④ t = 0〜15 s の変位は？</span>
        <input type="number" data-answer placeholder="?">
        <span>m</span>
        <button data-check data-correct="30">確認</button>
        <span class="feedback" data-feedback></span>
      </div>
    </div>
  </div>
</div>

<style>
  .graph-trainer {
    background: #f8fafc;
    border-radius: 16px;
    padding: 24px;
    margin: 24px 0;
  }

  .trainer-header {
    text-align: center;
    margin-bottom: 20px;
  }

  .trainer-header h3 {
    color: #0f172a;
    margin: 0;
  }

  .subtitle {
    color: #64748b;
    margin: 4px 0 0;
  }

  /* 小车轨道 */
  .sim-section {
    background: #fff;
    border: 2px solid #e2e8f0;
    border-radius: 16px;
    padding: 20px;
    margin-bottom: 20px;
  }

  .car-track {
    position: relative;
    height: 60px;
    margin-bottom: 20px;
  }

  .track-line {
    position: absolute;
    top: 50%;
    left: 5%;
    right: 5%;
    height: 4px;
    background: #94a3b8;
    border-radius: 2px;
  }

  .car {
    position: absolute;
    top: 50%;
    left: 5%;
    transform: translate(-50%, -50%);
    font-size: 2em;
    transition: left 0.05s linear;
  }

  .position-markers {
    position: absolute;
    top: 70%;
    left: 5%;
    right: 5%;
    font-size: 0.8em;
    color: #64748b;
  }

  .position-markers span {
    position: absolute;
    transform: translateX(-50%);
  }

  /* 双图 */
  .graphs-container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 16px;
    margin-bottom: 16px;
  }

  .graph-panel {
    background: #f8fafc;
    border-radius: 12px;
    padding: 12px;
  }

  .graph-label {
    text-align: center;
    font-size: 0.9em;
    color: #64748b;
    margin-bottom: 8px;
  }

  .graph-panel canvas {
    display: block;
    margin: 0 auto;
    max-width: 100%;
  }

  .playback-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
  }

  .play-btn, .reset-btn {
    padding: 10px 20px;
    border-radius: 20px;
    border: none;
    cursor: pointer;
    font-size: 1em;
    min-height: 44px;
  }

  .play-btn {
    background: #8b5cf6;
    color: white;
  }

  .reset-btn {
    background: #e2e8f0;
    color: #64748b;
  }

  .time-display {
    background: #1e293b;
    color: #22d3ee;
    padding: 8px 16px;
    border-radius: 8px;
    font-family: 'Courier New', monospace;
    font-weight: 600;
  }

  /* 概念卡 */
  .concepts-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 12px;
    margin-bottom: 20px;
  }

  .concept-card {
    background: #fff;
    border: 2px solid #e2e8f0;
    border-radius: 12px;
    padding: 16px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .concept-icon {
    font-size: 1.8em;
  }

  .concept-text {
    font-size: 0.9em;
    color: #0f172a;
    line-height: 1.4;
  }

  /* 练习 */
  .practice-section {
    background: #fff;
    border: 2px solid #e2e8f0;
    border-radius: 16px;
    padding: 20px;
  }

  .practice-section h4 {
    color: #0f172a;
    margin: 0 0 16px;
  }

  .quiz-grid {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .quiz-item {
    display: flex;
    align-items: center;
    gap: 8px;
    background: #f8fafc;
    padding: 12px;
    border-radius: 8px;
    flex-wrap: wrap;
  }

  .quiz-item span:first-child {
    flex: 1;
    min-width: 180px;
  }

  .quiz-item input {
    width: 60px;
    padding: 8px;
    border: 2px solid #e2e8f0;
    border-radius: 6px;
    text-align: center;
  }

  .quiz-item button {
    background: #8b5cf6;
    color: white;
    border: none;
    padding: 8px 12px;
    border-radius: 6px;
    cursor: pointer;
  }

  .feedback.correct { color: #16a34a; }
  .feedback.wrong { color: #dc2626; }
</style>

<script>
  document.querySelectorAll('[data-graph-trainer]').forEach(container => {
    const xtCanvas = container.querySelector('[data-xt-canvas]');
    const vtCanvas = container.querySelector('[data-vt-canvas]');
    const car = container.querySelector('[data-car]');
    const timeDisplay = container.querySelector('[data-time]');
    const playBtn = container.querySelector('[data-play]');
    const resetBtn = container.querySelector('[data-reset]');
    
    const xtCtx = xtCanvas.getContext('2d');
    const vtCtx = vtCanvas.getContext('2d');
    
    // 运动数据：0-10s加速，10-15s静止，15-20s减速
    const motion = [
      { tStart: 0, tEnd: 10, x0: 0, v0: 0, v1: 3 },   // 等速 v=3
      { tStart: 10, tEnd: 15, x0: 30, v0: 0, v1: 0 },  // 静止
      { tStart: 15, tEnd: 20, x0: 30, v0: -4, v1: -4 } // 等速 v=-4
    ];
    
    let animId = null;
    let currentTime = 0;
    let isPlaying = false;
    
    function getState(t) {
      let x = 0, v = 0;
      
      if (t <= 10) {
        v = 3;
        x = 3 * t;
      } else if (t <= 15) {
        v = 0;
        x = 30;
      } else if (t <= 20) {
        v = -4;
        x = 30 - 4 * (t - 15);
      } else {
        v = 0;
        x = 10;
      }
      
      return { x, v };
    }
    
    function setupCanvas(canvas, ctx) {
      const dpr = window.devicePixelRatio || 1;
      const rect = canvas.getBoundingClientRect();
      canvas.width = rect.width * dpr;
      canvas.height = 180 * dpr;
      ctx.scale(dpr, dpr);
      canvas.style.width = rect.width + 'px';
      canvas.style.height = '180px';
    }
    
    function drawXTGraph(highlightT) {
      setupCanvas(xtCanvas, xtCtx);
      const w = xtCanvas.getBoundingClientRect().width;
      const h = 180;
      const margin = { left: 40, right: 10, top: 10, bottom: 30 };
      const gw = w - margin.left - margin.right;
      const gh = h - margin.top - margin.bottom;
      
      xtCtx.clearRect(0, 0, w, h);
      
      // 网格
      xtCtx.strokeStyle = '#e2e8f0';
      xtCtx.lineWidth = 1;
      for (let i = 0; i <= 20; i += 5) {
        const x = margin.left + (i / 20) * gw;
        xtCtx.beginPath();
        xtCtx.moveTo(x, margin.top);
        xtCtx.lineTo(x, margin.top + gh);
        xtCtx.stroke();
      }
      for (let i = 0; i <= 40; i += 10) {
        const y = margin.top + gh - (i / 40) * gh;
        xtCtx.beginPath();
        xtCtx.moveTo(margin.left, y);
        xtCtx.lineTo(margin.left + gw, y);
        xtCtx.stroke();
      }
      
      // 坐标轴
      xtCtx.strokeStyle = '#64748b';
      xtCtx.lineWidth = 2;
      xtCtx.beginPath();
      xtCtx.moveTo(margin.left, margin.top);
      xtCtx.lineTo(margin.left, margin.top + gh);
      xtCtx.lineTo(margin.left + gw, margin.top + gh);
      xtCtx.stroke();
      
      // 标签
      xtCtx.fillStyle = '#64748b';
      xtCtx.font = '12px sans-serif';
      xtCtx.textAlign = 'center';
      xtCtx.fillText('t(s)', margin.left + gw / 2, h - 5);
      xtCtx.fillText('0', margin.left, h - 12);
      xtCtx.fillText('20', margin.left + gw, h - 12);
      xtCtx.textAlign = 'right';
      xtCtx.fillText('x(m)', margin.left - 5, margin.top + 10);
      xtCtx.fillText('40', margin.left - 5, margin.top + 5);
      
      // 曲线
      xtCtx.strokeStyle = '#8b5cf6';
      xtCtx.lineWidth = 3;
      xtCtx.beginPath();
      for (let t = 0; t <= 20; t += 0.5) {
        const { x } = getState(t);
        const px = margin.left + (t / 20) * gw;
        const py = margin.top + gh - (x / 40) * gh;
        if (t === 0) xtCtx.moveTo(px, py);
        else xtCtx.lineTo(px, py);
      }
      xtCtx.stroke();
      
      // 当前点
      if (highlightT !== undefined) {
        const { x } = getState(highlightT);
        const px = margin.left + (highlightT / 20) * gw;
        const py = margin.top + gh - (x / 40) * gh;
        xtCtx.fillStyle = '#ef4444';
        xtCtx.beginPath();
        xtCtx.arc(px, py, 6, 0, Math.PI * 2);
        xtCtx.fill();
      }
    }
    
    function drawVTGraph(highlightT) {
      setupCanvas(vtCanvas, vtCtx);
      const w = vtCanvas.getBoundingClientRect().width;
      const h = 180;
      const margin = { left: 40, right: 10, top: 10, bottom: 30 };
      const gw = w - margin.left - margin.right;
      const gh = h - margin.top - margin.bottom;
      const zeroY = margin.top + gh * 0.6; // v=0 的位置
      
      vtCtx.clearRect(0, 0, w, h);
      
      // 网格
      vtCtx.strokeStyle = '#e2e8f0';
      vtCtx.lineWidth = 1;
      for (let i = 0; i <= 20; i += 5) {
        const x = margin.left + (i / 20) * gw;
        vtCtx.beginPath();
        vtCtx.moveTo(x, margin.top);
        vtCtx.lineTo(x, margin.top + gh);
        vtCtx.stroke();
      }
      
      // v=0 线
      vtCtx.strokeStyle = '#94a3b8';
      vtCtx.setLineDash([4, 4]);
      vtCtx.beginPath();
      vtCtx.moveTo(margin.left, zeroY);
      vtCtx.lineTo(margin.left + gw, zeroY);
      vtCtx.stroke();
      vtCtx.setLineDash([]);
      
      // 坐标轴
      vtCtx.strokeStyle = '#64748b';
      vtCtx.lineWidth = 2;
      vtCtx.beginPath();
      vtCtx.moveTo(margin.left, margin.top);
      vtCtx.lineTo(margin.left, margin.top + gh);
      vtCtx.lineTo(margin.left + gw, margin.top + gh);
      vtCtx.stroke();
      
      // 标签
      vtCtx.fillStyle = '#64748b';
      vtCtx.font = '12px sans-serif';
      vtCtx.textAlign = 'center';
      vtCtx.fillText('t(s)', margin.left + gw / 2, h - 5);
      vtCtx.textAlign = 'right';
      vtCtx.fillText('v(m/s)', margin.left - 5, margin.top + 10);
      vtCtx.fillText('0', margin.left - 5, zeroY + 4);
      
      // 填充面积
      vtCtx.fillStyle = 'rgba(139, 92, 246, 0.2)';
      vtCtx.beginPath();
      vtCtx.moveTo(margin.left, zeroY);
      for (let t = 0; t <= 20; t += 0.5) {
        const { v } = getState(t);
        const px = margin.left + (t / 20) * gw;
        const py = zeroY - (v / 6) * (gh * 0.5);
        vtCtx.lineTo(px, py);
      }
      vtCtx.lineTo(margin.left + gw, zeroY);
      vtCtx.closePath();
      vtCtx.fill();
      
      // 曲线
      vtCtx.strokeStyle = '#22c55e';
      vtCtx.lineWidth = 3;
      vtCtx.beginPath();
      for (let t = 0; t <= 20; t += 0.5) {
        const { v } = getState(t);
        const px = margin.left + (t / 20) * gw;
        const py = zeroY - (v / 6) * (gh * 0.5);
        if (t === 0) vtCtx.moveTo(px, py);
        else vtCtx.lineTo(px, py);
      }
      vtCtx.stroke();
      
      // 当前点
      if (highlightT !== undefined) {
        const { v } = getState(highlightT);
        const px = margin.left + (highlightT / 20) * gw;
        const py = zeroY - (v / 6) * (gh * 0.5);
        vtCtx.fillStyle = '#ef4444';
        vtCtx.beginPath();
        vtCtx.arc(px, py, 6, 0, Math.PI * 2);
        vtCtx.fill();
      }
    }
    
    function updateDisplay(t) {
      const { x } = getState(t);
      car.style.left = `calc(5% + ${(x / 40) * 90}%)`;
      timeDisplay.textContent = t.toFixed(1);
      drawXTGraph(t);
      drawVTGraph(t);
    }
    
    function play() {
      if (isPlaying) return;
      isPlaying = true;
      playBtn.textContent = '⏸️ 一時停止';
      
      const startTime = performance.now() - currentTime * 1000;
      
      function animate(now) {
        if (!isPlaying) return;
        
        currentTime = (now - startTime) / 1000;
        if (currentTime > 20) {
          currentTime = 20;
          isPlaying = false;
          playBtn.textContent = '▶️ 再生';
        }
        
        updateDisplay(currentTime);
        
        if (isPlaying) {
          animId = requestAnimationFrame(animate);
        }
      }
      
      animId = requestAnimationFrame(animate);
    }
    
    function pause() {
      isPlaying = false;
      playBtn.textContent = '▶️ 再生';
      if (animId) cancelAnimationFrame(animId);
    }
    
    function reset() {
      pause();
      currentTime = 0;
      updateDisplay(0);
    }
    
    playBtn?.addEventListener('click', () => {
      if (isPlaying) pause();
      else play();
    });
    
    resetBtn?.addEventListener('click', reset);
    
    // 答题
    container.querySelectorAll('[data-check]').forEach(btn => {
      btn.addEventListener('click', () => {
        const item = btn.closest('[data-quiz]');
        const input = item.querySelector('[data-answer]');
        const fb = item.querySelector('[data-feedback]');
        const correct = parseFloat(btn.dataset.correct);
        const user = parseFloat(input.value);
        
        if (isNaN(user)) return;
        
        if (Math.abs(user - correct) < 0.1) {
          fb.className = 'feedback correct';
          fb.textContent = '✅';
        } else {
          fb.className = 'feedback wrong';
          fb.textContent = '❌ ' + correct;
        }
      });
    });
    
    // 页面离开清理
    document.addEventListener('astro:before-swap', () => {
      if (animId) cancelAnimationFrame(animId);
    });
    
    // 初始化
    updateDisplay(0);
  });
</script>
