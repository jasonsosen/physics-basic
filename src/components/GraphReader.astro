---
// Week 09: x-t / v-t グラフ読み取り
---

<div class="graph-trainer">
  <div class="trainer-header">
    <h3>📈 グラフの読み取り</h3>
    <div class="graph-toggle">
      <button class="toggle-btn active" data-type="xt">x-t グラフ</button>
      <button class="toggle-btn" data-type="vt">v-t グラフ</button>
    </div>
  </div>

  <div class="graph-card">
    <canvas id="graphCanvas" width="450" height="300"></canvas>
    <div class="graph-legend" id="graphLegend"></div>
  </div>

  <div class="reading-section">
    <h4>🔍 グラフから読み取ろう</h4>
    <div class="questions" id="questions">
      <!-- 動態生成 -->
    </div>
  </div>

  <div class="key-concepts">
    <div class="concept-card">
      <div class="concept-icon">📐</div>
      <div class="concept-text">
        <strong>x-tグラフ</strong><br>
        傾き = 速度
      </div>
    </div>
    <div class="concept-card">
      <div class="concept-icon">📊</div>
      <div class="concept-text">
        <strong>v-tグラフ</strong><br>
        傾き = 加速度<br>
        面積 = 変位
      </div>
    </div>
  </div>
</div>

<style>
  .graph-trainer {
    background: #f8fafc;
    border-radius: 16px;
    padding: 24px;
    margin: 24px 0;
  }

  .trainer-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
    flex-wrap: wrap;
    gap: 12px;
  }

  .trainer-header h3 {
    color: #0f172a;
    margin: 0;
  }

  .graph-toggle {
    display: flex;
    gap: 8px;
  }

  .toggle-btn {
    background: #fff;
    border: 2px solid #e2e8f0;
    padding: 8px 16px;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s;
    min-height: 44px;
  }

  .toggle-btn.active {
    background: #8b5cf6;
    border-color: #8b5cf6;
    color: white;
  }

  .graph-card {
    background: #fff;
    border: 2px solid #e2e8f0;
    border-radius: 16px;
    padding: 20px;
    margin-bottom: 20px;
  }

  #graphCanvas {
    width: 100%;
    max-width: 450px;
    height: auto;
    display: block;
    margin: 0 auto;
  }

  .graph-legend {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-top: 12px;
    font-size: 0.9em;
    color: #64748b;
  }

  .reading-section {
    background: #fff;
    border: 2px solid #e2e8f0;
    border-radius: 16px;
    padding: 20px;
    margin-bottom: 20px;
  }

  .reading-section h4 {
    color: #0f172a;
    margin: 0 0 16px 0;
  }

  .question-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px;
    background: #f8fafc;
    border-radius: 8px;
    margin-bottom: 12px;
    flex-wrap: wrap;
  }

  .question-text {
    flex: 1;
    min-width: 200px;
    color: #0f172a;
  }

  .question-input {
    width: 80px;
    padding: 10px;
    border: 2px solid #e2e8f0;
    border-radius: 8px;
    text-align: center;
  }

  .question-input:focus {
    outline: none;
    border-color: #8b5cf6;
  }

  .question-unit {
    color: #64748b;
    min-width: 50px;
  }

  .question-check {
    background: #8b5cf6;
    color: white;
    border: none;
    padding: 10px 16px;
    border-radius: 8px;
    cursor: pointer;
    min-height: 44px;
  }

  .question-feedback {
    width: 100%;
    padding: 10px;
    border-radius: 6px;
    margin-top: 8px;
    display: none;
  }

  .question-feedback.show { display: block; }
  .question-feedback.correct { background: #d1fae5; color: #065f46; }
  .question-feedback.wrong { background: #fee2e2; color: #991b1b; }

  .key-concepts {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 16px;
  }

  .concept-card {
    background: linear-gradient(135deg, #ede9fe, #ddd6fe);
    border-radius: 12px;
    padding: 16px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .concept-icon {
    font-size: 2em;
  }

  .concept-text {
    color: #5b21b6;
    font-size: 0.95em;
    line-height: 1.5;
  }

  @media (max-width: 640px) {
    .question-row { flex-direction: column; align-items: stretch; }
    .question-input { width: 100%; }
  }
</style>

<script>
  const canvas = document.getElementById('graphCanvas');
  const ctx = canvas.getContext('2d');
  
  let graphType = 'xt';
  
  // x-t 圖數據 (基於小測驗)
  const xtData = {
    points: [
      { t: 0, x: 0 },
      { t: 10, x: 30 },
      { t: 15, x: 30 },
      { t: 20, x: 10 }
    ],
    questions: [
      { text: 't = 0〜10 s の速度は？', answer: 3, unit: 'm/s', hint: '傾き = Δx/Δt = 30/10' },
      { text: 't = 10〜15 s の速度は？', answer: 0, unit: 'm/s', hint: '水平 → 静止' },
      { text: 't = 15〜20 s の速度は？', answer: -4, unit: 'm/s', hint: '下がっている → 負' },
      { text: 't = 0〜15 s の平均速度は？', answer: 2, unit: 'm/s', hint: 'Δx/Δt = 30/15' }
    ]
  };
  
  // v-t 圖數據
  const vtData = {
    points: [
      { t: 0, v: 0 },
      { t: 4, v: 8 },
      { t: 8, v: 8 },
      { t: 12, v: 0 }
    ],
    questions: [
      { text: 't = 0〜4 s の加速度は？', answer: 2, unit: 'm/s²', hint: '傾き = Δv/Δt = 8/4' },
      { text: 't = 4〜8 s の加速度は？', answer: 0, unit: 'm/s²', hint: '速度一定 → 等速' },
      { text: 't = 0〜8 s の変位は？', answer: 48, unit: 'm', hint: '面積 = 台形 = (0+8)×4/2 + 8×4' },
      { text: 't = 8〜12 s の変位は？', answer: 16, unit: 'm', hint: '三角形の面積 = 8×4/2' }
    ]
  };

  function drawGraph() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    const data = graphType === 'xt' ? xtData : vtData;
    const yLabel = graphType === 'xt' ? 'x (m)' : 'v (m/s)';
    
    const margin = { top: 30, right: 30, bottom: 40, left: 50 };
    const w = canvas.width - margin.left - margin.right;
    const h = canvas.height - margin.top - margin.bottom;
    
    // 計算比例
    const maxT = Math.max(...data.points.map(p => p.t));
    const maxY = graphType === 'xt' 
      ? Math.max(...data.points.map(p => p.x))
      : Math.max(...data.points.map(p => p.v));
    const minY = graphType === 'xt'
      ? Math.min(...data.points.map(p => p.x), 0)
      : 0;
    
    const scaleX = w / maxT;
    const scaleY = h / (maxY - minY + 5);
    
    // 網格
    ctx.strokeStyle = '#e2e8f0';
    ctx.lineWidth = 1;
    for (let i = 0; i <= maxT; i += 5) {
      const x = margin.left + i * scaleX;
      ctx.beginPath();
      ctx.moveTo(x, margin.top);
      ctx.lineTo(x, margin.top + h);
      ctx.stroke();
      
      ctx.fillStyle = '#64748b';
      ctx.font = '12px sans-serif';
      ctx.textAlign = 'center';
      ctx.fillText(i.toString(), x, margin.top + h + 20);
    }
    
    for (let i = 0; i <= maxY; i += 10) {
      const y = margin.top + h - (i - minY) * scaleY;
      ctx.beginPath();
      ctx.moveTo(margin.left, y);
      ctx.lineTo(margin.left + w, y);
      ctx.stroke();
      
      ctx.textAlign = 'right';
      ctx.fillText(i.toString(), margin.left - 8, y + 4);
    }
    
    // 坐標軸
    ctx.strokeStyle = '#1e293b';
    ctx.lineWidth = 2;
    ctx.beginPath();
    ctx.moveTo(margin.left, margin.top);
    ctx.lineTo(margin.left, margin.top + h);
    ctx.lineTo(margin.left + w, margin.top + h);
    ctx.stroke();
    
    // 軸標籤
    ctx.fillStyle = '#1e293b';
    ctx.font = 'bold 14px sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText('t (s)', margin.left + w/2, canvas.height - 5);
    ctx.save();
    ctx.translate(15, margin.top + h/2);
    ctx.rotate(-Math.PI/2);
    ctx.fillText(yLabel, 0, 0);
    ctx.restore();
    
    // 繪製曲線
    ctx.strokeStyle = '#8b5cf6';
    ctx.lineWidth = 3;
    ctx.beginPath();
    
    data.points.forEach((p, i) => {
      const x = margin.left + p.t * scaleX;
      const y = margin.top + h - ((graphType === 'xt' ? p.x : p.v) - minY) * scaleY;
      
      if (i === 0) ctx.moveTo(x, y);
      else ctx.lineTo(x, y);
    });
    ctx.stroke();
    
    // 繪製點
    ctx.fillStyle = '#8b5cf6';
    data.points.forEach(p => {
      const x = margin.left + p.t * scaleX;
      const y = margin.top + h - ((graphType === 'xt' ? p.x : p.v) - minY) * scaleY;
      ctx.beginPath();
      ctx.arc(x, y, 5, 0, Math.PI * 2);
      ctx.fill();
    });
    
    // v-t 圖顯示面積
    if (graphType === 'vt') {
      ctx.fillStyle = 'rgba(139, 92, 246, 0.2)';
      ctx.beginPath();
      ctx.moveTo(margin.left, margin.top + h);
      data.points.forEach(p => {
        const x = margin.left + p.t * scaleX;
        const y = margin.top + h - p.v * scaleY;
        ctx.lineTo(x, y);
      });
      ctx.lineTo(margin.left + data.points[data.points.length-1].t * scaleX, margin.top + h);
      ctx.closePath();
      ctx.fill();
    }
  }

  function renderQuestions() {
    const data = graphType === 'xt' ? xtData : vtData;
    const container = document.getElementById('questions');
    
    container.innerHTML = data.questions.map((q, i) => `
      <div class="question-row">
        <span class="question-text">${q.text}</span>
        <input type="number" class="question-input" id="q${i}" step="any">
        <span class="question-unit">${q.unit}</span>
        <button class="question-check" data-idx="${i}">確認</button>
        <div class="question-feedback" id="fb${i}"></div>
      </div>
    `).join('');
    
    container.querySelectorAll('.question-check').forEach(btn => {
      btn.addEventListener('click', () => {
        const idx = parseInt(btn.dataset.idx);
        const input = document.getElementById(`q${idx}`);
        const feedback = document.getElementById(`fb${idx}`);
        const q = data.questions[idx];
        const userAnswer = parseFloat(input.value);
        
        if (Math.abs(userAnswer - q.answer) < 0.1) {
          feedback.className = 'question-feedback show correct';
          feedback.textContent = `✅ 正解！ ${q.hint}`;
        } else {
          feedback.className = 'question-feedback show wrong';
          feedback.textContent = `❌ 不正解。正解: ${q.answer} ${q.unit}（${q.hint}）`;
        }
      });
    });
  }

  function updateLegend() {
    const legend = document.getElementById('graphLegend');
    if (graphType === 'xt') {
      legend.innerHTML = '📌 傾き = 速度　|　水平 = 静止　|　下向き = 負の速度';
    } else {
      legend.innerHTML = '📌 傾き = 加速度　|　面積 = 変位　|　水平 = 等速';
    }
  }

  // 切換圖類型
  document.querySelectorAll('.toggle-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.toggle-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      graphType = btn.dataset.type;
      drawGraph();
      renderQuestions();
      updateLegend();
    });
  });

  document.addEventListener('DOMContentLoaded', () => {
    drawGraph();
    renderQuestions();
    updateLegend();
  });
</script>
