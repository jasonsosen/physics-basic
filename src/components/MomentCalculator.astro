---
// Week 08: 力のモーメント
---

<div class="moment-trainer">
  <div class="trainer-header">
    <h3>⚖️ 力のモーメント（トルク）</h3>
  </div>

  <!-- 視覺化 -->
  <div class="visual-card">
    <canvas id="momentCanvas" width="400" height="200"></canvas>
    <div class="controls-row">
      <div class="control-item">
        <label>支点からの距離 d:</label>
        <input type="range" id="distSlider" min="1" max="5" value="3" step="0.5">
        <span id="distValue">3.0 m</span>
      </div>
      <div class="control-item">
        <label>力 F:</label>
        <input type="range" id="forceSlider" min="1" max="10" value="6" step="0.5">
        <span id="forceValue">6.0 N</span>
      </div>
    </div>
    
    <div class="moment-result">
      <span class="moment-formula">M = F × d = </span>
      <span class="moment-value" id="momentResult">18.0 N·m</span>
    </div>
  </div>

  <!-- 概念說明 -->
  <div class="concept-cards">
    <div class="concept-card">
      <div class="concept-icon">🔧</div>
      <div class="concept-title">モーメントとは</div>
      <div class="concept-desc">物体を回転させる力の効果</div>
    </div>
    <div class="concept-card">
      <div class="concept-icon">📏</div>
      <div class="concept-title">うでの長さ</div>
      <div class="concept-desc">支点から力の作用線までの垂直距離</div>
    </div>
    <div class="concept-card">
      <div class="concept-icon">⚖️</div>
      <div class="concept-title">つりあい条件</div>
      <div class="concept-desc">時計回り = 反時計回り</div>
    </div>
  </div>

  <!-- 練習問題 -->
  <div class="practice-section">
    <h4>📝 小テストの問題</h4>
    <div class="problem-card">
      <p>長さ 1.0 m の棒（重さ 6.0 N）を A, B で支える</p>
      
      <div class="problem-grid">
        <div class="problem-item">
          <span>① Aまわりの重力によるモーメントは？</span>
          <div class="input-group">
            <input type="number" id="m1" placeholder="?">
            <span>N·m</span>
            <button onclick="checkM(1, 3)">確認</button>
          </div>
          <span class="fb" id="f1"></span>
        </div>
        
        <div class="problem-item">
          <span>② Bまわりの重力によるモーメントは？</span>
          <div class="input-group">
            <input type="number" id="m2" placeholder="?">
            <span>N·m</span>
            <button onclick="checkM(2, -3)">確認</button>
          </div>
          <span class="fb" id="f2"></span>
        </div>
      </div>
      
      <div class="hint-box">
        💡 重心は棒の中央（0.5m）、モーメント = 6 × 0.5 = 3 N·m
      </div>
    </div>
  </div>
</div>

<style>
  .moment-trainer {
    background: #f8fafc;
    border-radius: 16px;
    padding: 24px;
    margin: 24px 0;
  }

  .trainer-header h3 {
    color: #0f172a;
    margin: 0 0 24px 0;
    text-align: center;
  }

  .visual-card {
    background: #fff;
    border: 2px solid #e2e8f0;
    border-radius: 16px;
    padding: 20px;
    margin-bottom: 24px;
    text-align: center;
  }

  #momentCanvas {
    display: block;
    margin: 0 auto 16px;
    max-width: 100%;
  }

  .controls-row {
    display: flex;
    gap: 24px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }

  .control-item {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .control-item label {
    color: #64748b;
    font-size: 0.9em;
  }

  .control-item input[type="range"] {
    width: 100px;
  }

  .moment-result {
    background: #dbeafe;
    border-radius: 8px;
    padding: 16px;
    font-size: 1.2em;
  }

  .moment-formula {
    color: #64748b;
  }

  .moment-value {
    color: #1d4ed8;
    font-weight: 700;
  }

  .concept-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 12px;
    margin-bottom: 24px;
  }

  .concept-card {
    background: #fff;
    border: 2px solid #e2e8f0;
    border-radius: 12px;
    padding: 16px;
    text-align: center;
  }

  .concept-icon { font-size: 2em; }
  .concept-title { font-weight: 600; color: #0f172a; margin: 8px 0 4px; }
  .concept-desc { font-size: 0.85em; color: #64748b; }

  .practice-section {
    background: #fff;
    border: 2px solid #e2e8f0;
    border-radius: 16px;
    padding: 20px;
  }

  .practice-section h4 {
    color: #0f172a;
    margin: 0 0 16px 0;
  }

  .problem-card {
    background: #f8fafc;
    border-radius: 12px;
    padding: 16px;
  }

  .problem-card p {
    margin-bottom: 16px;
  }

  .problem-grid {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .problem-item {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .input-group {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .input-group input {
    width: 80px;
    padding: 8px;
    border: 2px solid #e2e8f0;
    border-radius: 6px;
    text-align: center;
  }

  .input-group button {
    background: #8b5cf6;
    color: white;
    border: none;
    padding: 8px 12px;
    border-radius: 6px;
    cursor: pointer;
  }

  .fb.correct { color: #10b981; }
  .fb.wrong { color: #ef4444; }

  .hint-box {
    margin-top: 16px;
    padding: 12px;
    background: #fef3c7;
    border-radius: 8px;
    color: #92400e;
  }
</style>

<script>
  const canvas = document.getElementById('momentCanvas');
  const ctx = canvas.getContext('2d');

  function draw() {
    const d = parseFloat(document.getElementById('distSlider').value);
    const F = parseFloat(document.getElementById('forceSlider').value);
    
    document.getElementById('distValue').textContent = d.toFixed(1) + ' m';
    document.getElementById('forceValue').textContent = F.toFixed(1) + ' N';
    document.getElementById('momentResult').textContent = (d * F).toFixed(1) + ' N·m';
    
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    
    // 支點
    const pivotX = 80;
    const pivotY = 150;
    
    ctx.fillStyle = '#64748b';
    ctx.beginPath();
    ctx.moveTo(pivotX, pivotY);
    ctx.lineTo(pivotX - 15, pivotY + 25);
    ctx.lineTo(pivotX + 15, pivotY + 25);
    ctx.closePath();
    ctx.fill();
    
    // 槓桿
    const leverLen = d * 50;
    ctx.strokeStyle = '#8b5cf6';
    ctx.lineWidth = 8;
    ctx.lineCap = 'round';
    ctx.beginPath();
    ctx.moveTo(pivotX, pivotY);
    ctx.lineTo(pivotX + leverLen, pivotY);
    ctx.stroke();
    
    // 力的作用點
    const forceX = pivotX + leverLen;
    ctx.fillStyle = '#3b82f6';
    ctx.beginPath();
    ctx.arc(forceX, pivotY, 8, 0, Math.PI * 2);
    ctx.fill();
    
    // 力箭頭
    const arrowLen = F * 8;
    ctx.strokeStyle = '#ef4444';
    ctx.fillStyle = '#ef4444';
    ctx.lineWidth = 3;
    ctx.beginPath();
    ctx.moveTo(forceX, pivotY);
    ctx.lineTo(forceX, pivotY + arrowLen);
    ctx.stroke();
    
    // 箭頭頭部
    ctx.beginPath();
    ctx.moveTo(forceX, pivotY + arrowLen);
    ctx.lineTo(forceX - 8, pivotY + arrowLen - 10);
    ctx.lineTo(forceX + 8, pivotY + arrowLen - 10);
    ctx.closePath();
    ctx.fill();
    
    // 標籤
    ctx.fillStyle = '#ef4444';
    ctx.font = 'bold 14px sans-serif';
    ctx.fillText('F', forceX + 12, pivotY + arrowLen/2);
    
    // 距離標註
    ctx.strokeStyle = '#10b981';
    ctx.lineWidth = 2;
    ctx.setLineDash([5, 3]);
    ctx.beginPath();
    ctx.moveTo(pivotX, pivotY - 30);
    ctx.lineTo(forceX, pivotY - 30);
    ctx.stroke();
    ctx.setLineDash([]);
    
    ctx.fillStyle = '#10b981';
    ctx.fillText('d = ' + d.toFixed(1) + ' m', (pivotX + forceX)/2 - 20, pivotY - 35);
    
    // 旋轉箭頭
    ctx.strokeStyle = '#f59e0b';
    ctx.lineWidth = 2;
    ctx.beginPath();
    ctx.arc(pivotX, pivotY, 30, -0.5, 0.8);
    ctx.stroke();
    
    ctx.fillStyle = '#f59e0b';
    ctx.font = '12px sans-serif';
    ctx.fillText('M', pivotX + 35, pivotY + 10);
  }

  document.getElementById('distSlider')?.addEventListener('input', draw);
  document.getElementById('forceSlider')?.addEventListener('input', draw);

  window.checkM = function(n, ans) {
    const input = document.getElementById(`m${n}`);
    const fb = document.getElementById(`f${n}`);
    if (Math.abs(parseFloat(input.value) - ans) < 0.1) {
      fb.className = 'fb correct';
      fb.textContent = '✅ 正解！';
    } else {
      fb.className = 'fb wrong';
      fb.textContent = `❌ 正解: ${ans}`;
    }
  };

  document.addEventListener('DOMContentLoaded', draw);
</script>
