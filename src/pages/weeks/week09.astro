---
import TabView from '../../components/TabView.astro';
import Layout from '../../layouts/Layout.astro';
import QuizCard from '../../components/QuizCard.astro';
import Math from '../../components/Math.astro';
---

<Layout title="Week 9: 運動の表し方">
  <h1>Week 9: 運動の表し方</h1>

  <TabView>
    <!-- ========== 内容タブ ========== -->
    <div slot="content">


  <!-- ===== Section 1: x-t グラフ ===== -->
  <section class="content-section">
    <h2>📈 x-t グラフ（位置-時間グラフ）</h2>
    
    <div class="intro-box">
      <strong>x-t グラフ</strong> では、縦軸が位置 $x$、横軸が時間 $t$ を表します。<br/>
      このグラフの <strong>傾き</strong> が <strong>速度 $v$</strong> になります！
    </div>

    <div class="formula-box">
      <h4>速度の求め方（グラフの傾き）</h4>
      <Math f="v = \\frac{\\Delta x}{\\Delta t} = \\frac{x_2 - x_1}{t_2 - t_1}" block />
      <p>※ $\Delta$（デルタ）は「変化量」を意味します。</p>
    </div>

    <div class="simple-cases">
      <div class="case-card">
        <div class="case-icon">↗️</div>
        <div class="case-text"><strong>右上がり：</strong></div>
        <div class="case-example">速度 $v > 0$（正の向きに進む）</div>
      </div>
      <div class="case-card">
        <div class="case-icon">➡️</div>
        <div class="case-text"><strong>水平：</strong></div>
        <div class="case-example">速度 $v = 0$（止まっている）</div>
      </div>
      <div class="case-card">
        <div class="case-icon">↘️</div>
        <div class="case-text"><strong>右下がり：</strong></div>
        <div class="case-example">速度 $v < 0$（負の向きに進む）</div>
      </div>
    </div>
  </section>

  <!-- ===== Section 2: 平均の速度 ===== -->
  <section class="content-section">
    <h2>🏃 平均の速度</h2>

    <div class="formula-box">
      <Math f="平均の速度 = 総変位 / 総時間" block />
    </div>

    <div class="example-box">
      <h4>例：平均の速度の計算</h4>
      <p>ある物体が $t=0$ s で $x=2$ m にあり、$t=4$ s で $x=10$ m の位置に移動した。</p>
      <div class="solution-steps">
        <p>変位 $\Delta x = 10 - 2 = 8$ m</p>
        <p>時間 $\Delta t = 4 - 0 = 4$ s</p>
        <p>平均の速度 $v = 8 / 4 =$ <strong>2 m/s</strong></p>
      </div>
    </div>
  </section>
    </div>

    <!-- ========== 題目タブ ========== -->
    <div slot="problems">

      <!-- 基礎問題 -->
      <section class="content-section exercise-section">
        <h2>✏️ 基礎問題</h2>
        <p class="section-desc">公式の基本を確認しよう</p>
        <QuizCard 
      id="1"
      question="t=0 sでx=0 m、t=2 sでx=10 mにある物体の平均の速度は？"
      answer="5"
      answerUnit="m/s"
      steps={[
        "v = Δx / Δt",
        "= (10 - 0) / (2 - 0)",
        "= 10 / 2 = <strong>5 m/s</strong>"
      ]}
    />

<QuizCard 
      id="2"
      question="t=1 sでx=3 m、t=4 sでx=15 mにある物体の平均の速度は？"
      answer="4"
      answerUnit="m/s"
      steps={[
        "v = (15 - 3) / (4 - 1)",
        "= 12 / 3 = <strong>4 m/s</strong>"
      ]}
    />

<QuizCard 
      id="3"
      question="t=2 sでx=20 m、t=5 sでx=5 mに移動した。このときの平均の速度は？"
      answer="-5"
      answerUnit="m/s"
      steps={[
        "v = (5 - 20) / (5 - 2)",
        "= -15 / 3 = <strong>-5 m/s</strong>"
      ]}
    />
      </section>

      <!-- 陷阱問題 -->
      <section class="content-section exercise-section trap-section">
        <h2>🚨 陷阱チェック</h2>
        <p class="section-desc">間違えやすい単位換算や概念！</p>
        <QuizCard 
      id="4"
      question="x-tグラフが原点を通る直線で、t=5 sのときx=25 mである。この直線の傾き（速度）は？"
      answer="5"
      answerUnit="m/s"
      steps={[
        "v = 25 / 5 = <strong>5 m/s</strong>"
      ]}
    />
      </section>

      <!-- 総合問題 -->
      <section class="content-section exercise-section exam-section">
        <h2>🎓 総合問題</h2>
        <p class="section-desc">試験形式の文字式・総合問題</p>

        <div class="exam-problem">
          <div class="exam-question">
            <strong>【問】</strong> 次の文章を読み、指定された文字を用いて答えなさい。<br/>
            質量 <i>m</i> [kg] の物体に、一定の力 <i>F</i> [N] を加えたときの関係式を記述しなさい。（重力加速度を <i>g</i> とします）
          </div>
          <div class="exam-details">
            (1) 物体にかかる重力を求めよ。<br/>
            (2) 運動方程式を立てよ。
          </div>
          <details class="exam-answer">
            <summary>解答と解説を見る</summary>
            <div class="answer-content">
              <p><strong>解答：</strong></p>
              <p>(1) <i>W = mg</i></p>
              <p>(2) <i>F = ma</i> （<i>a</i> は加速度）</p>
              <p><strong>解説：</strong></p>
              <p>文字式で答える場合は、単位に注意しながら公式をそのまま適用します。</p>
            </div>
          </details>
        </div>
      </section>
    </div>
    </TabView>

  <div class="nav-buttons">
    <a href="/physics-basic/weeks/week08/" class="nav-btn secondary">← Week 8</a>
    <a href="/physics-basic/weeks/week10/" class="nav-btn">Week 10 へ →</a>
  </div>
</Layout>

<style>
  /* Base styles inherited from week04 layout */
  .content-section {
    margin: 40px 0;
    padding: 24px;
    background: #ffffff;
    border-radius: 16px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  }

  .content-section h2 {
    color: #1e293b;
    font-size: 1.5rem;
    margin-bottom: 20px;
    padding-bottom: 12px;
    border-bottom: 3px solid #3b82f6;
  }

  .intro-box {
    background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
    border-radius: 12px;
    padding: 20px;
    margin-bottom: 24px;
    font-size: 1.05rem;
  }

  .formula-box {
    background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
    border: 2px solid #3b82f6;
    border-radius: 12px;
    padding: 24px;
    text-align: center;
    margin: 24px 0;
  }

  .formula-box h4 {
    margin: 0 0 12px;
    color: #1d4ed8;
  }

  .big-formula {
    font-size: 1.5rem;
    font-weight: 700;
    color: #1d4ed8;
    display: block;
    margin: 8px 0;
    font-family: 'Courier New', monospace;
  }

  .simple-cases {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 16px;
    margin: 20px 0;
  }

  .case-card {
    background: #f8fafc;
    border: 2px solid #e2e8f0;
    border-radius: 12px;
    padding: 16px;
    text-align: center;
  }

  .case-icon {
    font-size: 1.5rem;
    margin-bottom: 8px;
  }

  .example-box {
    background: #f0fdf4;
    border: 2px solid #22c55e;
    border-radius: 12px;
    padding: 20px;
    margin: 20px 0;
  }

  .example-box h4 {
    color: #15803d;
    margin: 0 0 12px;
  }

  .solution-steps {
    background: white;
    padding: 12px 16px;
    border-radius: 8px;
    margin-top: 12px;
  }

  .solution-steps p {
    margin: 6px 0;
  }

  .exercise-section {
    background: #fafbfc;
  }

  .nav-buttons {
    display: flex;
    justify-content: space-between;
    margin-top: 40px;
    gap: 16px;
  }

  .nav-btn {
    flex: 1;
    display: inline-block;
    padding: 14px 24px;
    text-align: center;
    text-decoration: none;
    border-radius: 8px;
    font-weight: 600;
    transition: all 0.2s;
  }

  .nav-btn:not(.secondary) {
    background: #3b82f6;
    color: white;
  }

  .nav-btn:not(.secondary):hover {
    background: #2563eb;
  }

  .nav-btn.secondary {
    background: #f1f5f9;
    color: #475569;
  }

  .nav-btn.secondary:hover {
    background: #e2e8f0;
  }
</style>
