---
import Layout from '../../layouts/Layout.astro';
import TabView from '../../components/TabView.astro';
import QuizCard from '../../components/QuizCard.astro';
import Math from '../../components/Math.astro';
---

<Layout title="Week 3: 力と質量、密度">
  <h1>Week 3: 力と質量、密度</h1>

  <TabView>
    <!-- ========== 内容タブ ========== -->
    <div slot="content">
      <!-- 密度 -->
      <section class="content-section">
        <h2>📦 密度ってなんだろう？</h2>
        <div class="intro-box">
          <strong>🤔 なぜ鉄は重く、綿は軽い？</strong><br/>
          同じ大きさ（体積）で比べたときの「ぎっしり度」が違うから！
        </div>
        <div class="formula-box">
          <Math f="\\rho = \\frac{m}{V}" block />
          <p>密度 ＝ 質量 ÷ 体積</p>
        </div>
        <div class="formula-trio">
          <div class="formula-card"><div class="formula-icon">📐</div><div class="formula-text">ρ = m ÷ V</div><div class="formula-desc">密度を求める</div></div>
          <div class="formula-card"><div class="formula-icon">⚖️</div><div class="formula-text">m = ρ × V</div><div class="formula-desc">質量を求める</div></div>
          <div class="formula-card"><div class="formula-icon">📦</div><div class="formula-text">V = m ÷ ρ</div><div class="formula-desc">体積を求める</div></div>
        </div>
        <div class="density-table">
          <table>
            <tr><th>物質</th><th>密度 (g/cm³)</th><th>水に入れると</th></tr>
            <tr><td>水</td><td>1.00</td><td>（基準）</td></tr>
            <tr class="float"><td>木</td><td>約 0.5</td><td>🔼 浮く</td></tr>
            <tr class="sink"><td>鉄</td><td>7.87</td><td>🔽 沈む</td></tr>
          </table>
          <p class="table-note">📌 密度 < 1.0 → 水に浮く！</p>
        </div>
      </section>

      <!-- 質量と重さ -->
      <section class="content-section">
        <h2>⚖️ 質量と重さは違う！</h2>
        <div class="danger-box">
          <span class="danger-icon">⚠️</span>
          <span>最重要！「質量」と「重さ」を混同しないで！</span>
        </div>
        <div class="comparison-cards">
          <div class="comp-card mass-card">
            <h4>質量 (m)</h4>
            <ul>
              <li>物体の「中身の量」</li>
              <li>単位：<strong>kg</strong></li>
              <li>場所で変わる？ <strong>❌ 変わらない</strong></li>
            </ul>
          </div>
          <div class="comp-card weight-card">
            <h4>重さ・重力 (W)</h4>
            <ul>
              <li>星に引っ張られる力</li>
              <li>単位：<strong>N（ニュートン）</strong></li>
              <li>場所で変わる？ <strong>⭕ 変わる</strong></li>
            </ul>
          </div>
        </div>
        <div class="formula-box">
          <Math f="W = mg" block />
          <p>重力 ＝ 質量 × 重力加速度</p>
        </div>
        <div class="g-table">
          <table>
            <tr><th>場所</th><th>重力加速度 g</th></tr>
            <tr><td>地球</td><td>9.8 m/s² ≈ <strong>10</strong></td></tr>
            <tr><td>月</td><td>約 1.6 m/s²（地球の <strong>1/6</strong>）</td></tr>
          </table>
        </div>
      </section>

      <!-- 月での比較 -->
      <section class="content-section">
        <h2>🌙 月への旅行で考えよう</h2>
        <div class="moon-comparison">
          <div class="planet-card earth">
            <div class="planet-icon">🌍</div><h4>地球</h4>
            <p>質量：60 kg</p>
            <p class="highlight">重さ：<strong>600 N</strong></p>
          </div>
          <div class="arrow-container">🚀</div>
          <div class="planet-card moon">
            <div class="planet-icon">🌙</div><h4>月</h4>
            <p>質量：60 kg <span class="badge">同じ！</span></p>
            <p class="highlight">重さ：<strong>100 N</strong></p>
          </div>
        </div>
        <div class="trap-warning">
          <h4>🚨 陥りやすい罠！</h4>
          <p>「月に行ったら質量も1/6になる」→ <strong>❌ 間違い！</strong></p>
          <p>質量は物体の固有の性質。変わるのは<strong>重力（重さ）だけ！</strong></p>
        </div>
      </section>

      <!-- バネの力 -->
      <section class="content-section">
        <h2>🔩 バネの力（フックの法則）</h2>
        <div class="formula-box">
          <Math f="F = kx" block />
          <p>弾性力 ＝ バネ定数 × 伸び</p>
        </div>
        <div class="symbol-table">
          <table>
            <tr><th>記号</th><th>意味</th><th>単位</th></tr>
            <tr><td>F</td><td>弾性力</td><td>N</td></tr>
            <tr><td>k</td><td>バネ定数</td><td>N/m</td></tr>
            <tr><td>x</td><td>伸び</td><td>m</td></tr>
          </table>
        </div>
      </section>

      <!-- まとめ -->
      <section class="content-section summary-section">
        <h2>📝 今日のまとめ</h2>
        <div class="summary-grid">
          <div class="summary-item"><span class="summary-icon">📦</span><span>密度：<strong>ρ = m/V</strong></span></div>
          <div class="summary-item"><span class="summary-icon">⬇️</span><span>重力：<strong>W = mg</strong></span></div>
          <div class="summary-item"><span class="summary-icon">🔩</span><span>バネ：<strong>F = kx</strong></span></div>
          <div class="summary-item warning"><span class="summary-icon">⚠️</span><span><strong>質量は変わらない、重さは変わる！</strong></span></div>
        </div>
      </section>
    </div>

    <!-- ========== 題目タブ ========== -->
    <div slot="problems">
      <!-- Level 1: 密度 -->
      <section class="content-section exercise-section">
        <h2>✏️ Level 1：密度の計算</h2>
        <QuizCard id="1" question="質量 500 g、体積 100 cm³ の物体の密度" answer="5.0" answerUnit="g/cm³" steps={["ρ = m/V = 500 ÷ 100 = 5.0 g/cm³"]} />
        <QuizCard id="2" question="密度 2.5 g/cm³、体積 20 cm³ の物体の質量" answer="50" answerUnit="g" steps={["m = ρV = 2.5 × 20 = 50 g"]} />
        <QuizCard id="3" question="密度 7.8 g/cm³、質量 39 g の金属の体積" answer="5.0" answerUnit="cm³" steps={["V = m/ρ = 39 ÷ 7.8 = 5.0 cm³"]} />
      </section>

      <!-- Level 2: 重力 -->
      <section class="content-section exercise-section">
        <h2>✏️ Level 2：重力の計算</h2>
        <QuizCard id="4" question="質量 5 kg の物体の重力（g = 10）" answer="50" answerUnit="N" steps={["W = mg = 5 × 10 = 50 N"]} />
        <QuizCard id="5" question="質量 200 g のリンゴの重力（g = 10）" answer="2" answerUnit="N" steps={["200 g = 0.2 kg", "W = 0.2 × 10 = 2 N"]} hint="g → kg に換算！" />
        <QuizCard id="6" question="月で重さが 10 N の物体、地球での重さ" answer="60" answerUnit="N" steps={["地球 = 月 × 6 = 10 × 6 = 60 N"]} />
        <QuizCard id="7" question="重力 30 N を受けている物体の質量（g = 10）" answer="3" answerUnit="kg" steps={["m = W/g = 30 ÷ 10 = 3 kg"]} />
      </section>

      <!-- 陷阱チェック -->
      <section class="content-section exercise-section trap-section">
        <h2>🚨 陷阱チェック：質量 vs 重さ</h2>
        <p class="section-desc">間違える人が本当に多い！</p>
        <QuizCard id="8" question="宇宙飛行士の地球での質量は 72 kg。月に行ったら質量は？" answer="72" answerUnit="kg" steps={["質量は場所で変わらない！", "答え：72 kg（同じ）"]} hint="陷阱注意！" />
        <QuizCard id="9" question="地球で 600 N の重力を受ける人、月での重力は？" answer="100" answerUnit="N" steps={["月 = 地球 ÷ 6 = 600 ÷ 6 = 100 N"]} />
      </section>

      <!-- Level 3: バネ -->
      <section class="content-section exercise-section">
        <h2>✏️ Level 3：バネの計算</h2>
        <QuizCard id="10" question="バネ定数 50 N/m のバネが 0.2 m 伸びた時の弾性力" answer="10" answerUnit="N" steps={["F = kx = 50 × 0.2 = 10 N"]} />
        <QuizCard id="11" question="バネ定数 25 N/m のバネに物体を吊るしたら 0.24 m 伸びた。物体の重力は？" answer="6" answerUnit="N" steps={["F = kx = 25 × 0.24 = 6 N"]} />
        <QuizCard id="12" question="問11のバネと物体を月に持っていくと、伸びは？" answer="0.04" answerUnit="m" steps={["月での重力 = 6 ÷ 6 = 1 N", "x = F/k = 1 ÷ 25 = 0.04 m"]} hint="k は変わらない！" />
        <QuizCard id="13" question="問11の物体の質量は？（g = 10）" answer="0.6" answerUnit="kg" steps={["m = W/g = 6 ÷ 10 = 0.6 kg"]} />
        <QuizCard id="14" question="問11の物体を月に持っていった時の質量は？" answer="0.6" answerUnit="kg" steps={["質量は変わらない！0.6 kg"]} hint="また陷阱！" />
      </section>
    </div>
  </TabView>

  <div class="nav-buttons">
    <a href="/physics-basic/weeks/week02/" class="nav-btn secondary">← Week 2</a>
    <a href="/physics-basic/weeks/week04/" class="nav-btn">Week 4 へ →</a>
  </div>
</Layout>

<style>
  .content-section { margin: 20px 0; padding: 24px; background: #ffffff; border-radius: 16px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
  .content-section h2 { color: #1e293b; font-size: 1.5rem; margin-bottom: 20px; padding-bottom: 12px; border-bottom: 3px solid #3b82f6; }
  .section-desc { color: #64748b; margin-bottom: 20px; }
  .intro-box { background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%); border-radius: 12px; padding: 20px; margin-bottom: 24px; }
  .formula-box { background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%); border: 2px solid #3b82f6; border-radius: 12px; padding: 24px; text-align: center; margin: 24px 0; }
  .formula-box p { margin: 8px 0 0; color: #475569; }
  .formula-trio { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 12px; margin: 20px 0; }
  .formula-card { background: #f8fafc; border: 2px solid #e2e8f0; border-radius: 12px; padding: 16px; text-align: center; }
  .formula-card:hover { border-color: #3b82f6; }
  .formula-icon { font-size: 1.5rem; }
  .formula-text { font-weight: 600; font-family: monospace; }
  .formula-desc { font-size: 0.85rem; color: #64748b; }
  .density-table table, .symbol-table table, .g-table table { width: 100%; border-collapse: collapse; margin: 16px 0; }
  .density-table th, .density-table td, .symbol-table th, .symbol-table td, .g-table th, .g-table td { padding: 12px; border: 1px solid #e2e8f0; text-align: center; }
  .density-table th, .symbol-table th, .g-table th { background: #f1f5f9; }
  .density-table .float { background: #dcfce7; }
  .density-table .sink { background: #fee2e2; }
  .table-note { font-size: 0.9rem; color: #059669; margin-top: 8px; }
  .danger-box { background: linear-gradient(135deg, #fef2f2 0%, #fee2e2 100%); border: 2px solid #ef4444; border-radius: 12px; padding: 16px 20px; display: flex; align-items: center; gap: 12px; margin: 20px 0; }
  .danger-icon { font-size: 1.5rem; }
  .comparison-cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin: 20px 0; }
  .comp-card { border-radius: 12px; padding: 20px; }
  .comp-card h4 { text-align: center; margin-bottom: 12px; }
  .comp-card ul { list-style: none; padding: 0; }
  .comp-card li { padding: 6px 0; border-bottom: 1px solid rgba(0,0,0,0.1); }
  .mass-card { background: linear-gradient(135deg, #ecfdf5 0%, #d1fae5 100%); border: 2px solid #10b981; }
  .weight-card { background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%); border: 2px solid #f59e0b; }
  .moon-comparison { display: flex; align-items: center; justify-content: center; gap: 20px; flex-wrap: wrap; margin: 24px 0; }
  .planet-card { border-radius: 16px; padding: 20px; text-align: center; min-width: 150px; }
  .planet-card.earth { background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%); border: 2px solid #3b82f6; }
  .planet-card.moon { background: linear-gradient(135deg, #f3f4f6 0%, #e5e7eb 100%); border: 2px solid #6b7280; }
  .planet-icon { font-size: 2rem; }
  .planet-card .highlight { color: #dc2626; font-weight: 700; }
  .badge { background: #10b981; color: white; padding: 2px 6px; border-radius: 4px; font-size: 0.75rem; }
  .arrow-container { font-size: 2rem; }
  .trap-warning { background: linear-gradient(135deg, #fef2f2 0%, #fee2e2 100%); border: 3px solid #dc2626; border-radius: 12px; padding: 20px; margin: 20px 0; }
  .trap-warning h4 { color: #dc2626; margin: 0 0 12px; }
  .exercise-section { background: #fafbfc; }
  .trap-section { background: linear-gradient(135deg, #fff7ed 0%, #ffedd5 100%); border: 2px solid #f97316; }
  .trap-section h2 { border-color: #f97316; color: #c2410c; }
  .summary-section { background: linear-gradient(135deg, #ecfdf5 0%, #d1fae5 100%); border: 2px solid #10b981; }
  .summary-section h2 { border-color: #10b981; color: #059669; }
  .summary-grid { display: grid; gap: 12px; }
  .summary-item { display: flex; align-items: center; gap: 12px; }
  .summary-item.warning { color: #dc2626; font-weight: 600; }
  .summary-icon { font-size: 1.3rem; }
  .nav-buttons { display: flex; justify-content: space-between; margin-top: 40px; gap: 16px; }
  .nav-btn { flex: 1; display: inline-block; padding: 14px 24px; text-align: center; text-decoration: none; border-radius: 8px; font-weight: 600; transition: all 0.2s; }
  .nav-btn:not(.secondary) { background: #3b82f6; color: white; }
  .nav-btn:not(.secondary):hover { background: #2563eb; }
  .nav-btn.secondary { background: #f1f5f9; color: #475569; }
  .nav-btn.secondary:hover { background: #e2e8f0; }
</style>
