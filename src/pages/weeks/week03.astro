<script>
  document.addEventListener('DOMContentLoaded', () => {
    const cards = document.querySelectorAll('.quiz-card');
    
    cards.forEach(card => {
      const input = card.querySelector('.quiz-input') as HTMLInputElement;
      const btn = card.querySelector('.quiz-btn') as HTMLButtonElement;
      const solution = card.querySelector('.quiz-solution') as HTMLDivElement;
      
      const showAnswer = () => {
        solution.classList.remove('hidden');
        input.disabled = true;
        btn.disabled = true;
        btn.textContent = '回答済み';
        card.classList.add('answered');
        solution.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      };

      btn.addEventListener('click', showAnswer);
      input.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') {
          e.preventDefault();
          showAnswer();
        }
      });
    });
  });
</script>
