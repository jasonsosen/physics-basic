---
import TabView from '../../components/TabView.astro';
import Layout from '../../layouts/Layout.astro';
import QuizCard from '../../components/QuizCard.astro';
import Math from '../../components/Math.astro';
---

<Layout title="Week 7: 剛体と重心">
  <h1>Week 7: 剛体と重心</h1>

  <TabView>
    <!-- ========== 内容タブ ========== -->
    <div slot="content">


  <section class="content-section">
    <h2>🧱 剛体（ごうたい）とは？</h2>
    <div class="intro-box">
      力を加えても<strong>変形しない（形や大きさが変わらない）</strong>理想的な物体のこと。質点（大きさのない点）とは違い、「回転」を考える必要があります。
    </div>
  </section>

  <section class="content-section">
    <h2>📍 重心（じゅうしん）</h2>

    <div class="intro-box">
      物体の「重さのド真ん中」。指1本で支えたときに、釣り合う点のことです。
    </div>

    <div class="formula-box">
      <h4>2質点系の重心の公式（x座標）</h4>
      <Math f="x_G = (m_{1}x_{1} + m_{2}x_{2}) / (m_{1} + m_{2})" block />
      <p>m: 質量、x: 位置（座標）</p>
    </div>

    <div class="example-box">
      <h4>💡 重心の位置の直感的な理解</h4>
      <ul>
        <li><strong>m₁ = m₂ のとき（同じ質量）</strong><br/>重心はちょうど「中点」になります。（1:1の内分点）</li>
        <li><strong>m₁ = 3m₂ のとき（重さが違う）</strong><br/>重い方に近づきます。重さの比が 3:1 なら、距離の比は <strong>1:3（逆比）</strong> になります。</li>
      </ul>
    </div>
  </section>

  <!-- ===== まとめ ===== -->
  <section class="content-section summary-section">
    <h2>📝 今日のまとめ</h2>
    <div class="summary-grid">
      <div class="summary-item">
        <span class="summary-icon">🧱</span>
        <span>剛体：<strong>変形しない物体</strong>（回転を考える）</span>
      </div>
      <div class="summary-item">
        <span class="summary-icon">📍</span>
        <span>重心の公式：<strong>x_G = (m₁x₁ + m₂x₂) / (m₁ + m₂)</strong></span>
      </div>
      <div class="summary-item">
        <span class="summary-icon">⚖️</span>
        <span>直感：<strong>重い方に近づく！（逆比）</strong></span>
      </div>
    </div>
  </section>
    </div>

    <!-- ========== 題目タブ ========== -->
    <div slot="problems">

      <!-- 基礎問題 -->
      <section class="content-section exercise-section">
        <h2>✏️ 基礎問題</h2>
        <p class="section-desc">公式の基本を確認しよう</p>
        <QuizCard 
      id="1"
      question="質量 2 kg の物体A が x = 0 に、質量 2 kg の物体B が x = 10 にある。重心の x 座標は？"
      answer="5"
      answerUnit=""
      steps={[
        "質量が同じ(2kgと2kg)なので、中点になる。",
        "(0 + 10) / 2 = 5",
        "公式: (2×0 + 2×10) / (2+2) = 20 / 4 = 5"
      ]}
    />

<QuizCard 
      id="2"
      question="質量 3 kg の物体A が x = 0 に、質量 1 kg の物体B が x = 8 にある。重心の x 座標は？"
      answer="2"
      answerUnit=""
      steps={[
        "公式: x_G = (m₁x₁ + m₂x₂) / (m₁ + m₂)",
        "= (3×0 + 1×8) / (3 + 1)",
        "= 8 / 4 = 2",
        "※重さの比が 3:1 なので、距離の比は 1:3。重い方(x=0)に近い！"
      ]}
    />

<QuizCard 
      id="3"
      question="質量 1 kg の物体A が x = 2 に、質量 4 kg の物体B が x = 12 にある。重心の x 座標は？"
      answer="10"
      answerUnit=""
      steps={[
        "公式: x_G = (1×2 + 4×12) / (1 + 4)",
        "= (2 + 48) / 5",
        "= 50 / 5 = 10"
      ]}
    />
      </section>

      <!-- 陷阱問題 -->
      <section class="content-section exercise-section trap-section">
        <h2>🚨 陷阱チェック</h2>
        <p class="section-desc">間違えやすい単位換算や概念！</p>
        <QuizCard 
      id="4"
      question="質量 m₁ = 5 kg (x₁ = 0)、質量 m₂ = 5 kg (x₂ = 6)。重心は？"
      answer="3"
      answerUnit=""
      steps={[
        "質量が同じなので中点。 6 / 2 = 3"
      ]}
    />
      </section>

      <!-- 総合問題 -->
      <section class="content-section exercise-section exam-section">
        <h2>🎓 総合問題</h2>
        <p class="section-desc">試験形式の文字式・総合問題</p>

        <div class="exam-problem">
          <div class="exam-question">
            <strong>【問】</strong> 次の文章を読み、指定された文字を用いて答えなさい。<br/>
            質量 <i>m</i> [kg] の物体に、一定の力 <i>F</i> [N] を加えたときの関係式を記述しなさい。（重力加速度を <i>g</i> とします）
          </div>
          <div class="exam-details">
            (1) 物体にかかる重力を求めよ。<br/>
            (2) 運動方程式を立てよ。
          </div>
          <details class="exam-answer">
            <summary>解答と解説を見る</summary>
            <div class="answer-content">
              <p><strong>解答：</strong></p>
              <p>(1) <i>W = mg</i></p>
              <p>(2) <i>F = ma</i> （<i>a</i> は加速度）</p>
              <p><strong>解説：</strong></p>
              <p>文字式で答える場合は、単位に注意しながら公式をそのまま適用します。</p>
            </div>
          </details>
        </div>
      </section>
    </div>
    </TabView>

  <div class="nav-buttons">
    <a href="/physics-basic/weeks/week06/" class="nav-btn secondary">← Week 6</a>
    <a href="/physics-basic/weeks/week08/" class="nav-btn">Week 8 へ →</a>
  </div>
</Layout>

<style>
  /* Reuse standard styles */
  .content-section { margin: 40px 0; padding: 24px; background: #ffffff; border-radius: 16px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
  .content-section h2 { color: #1e293b; font-size: 1.5rem; margin-bottom: 20px; padding-bottom: 12px; border-bottom: 3px solid #3b82f6; }
  .intro-box { background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%); border-radius: 12px; padding: 20px; margin-bottom: 24px; font-size: 1.05rem; }
  .formula-box { background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%); border: 2px solid #3b82f6; border-radius: 12px; padding: 24px; text-align: center; margin: 24px 0; }
  .formula-box h4 { margin: 0 0 12px; color: #1d4ed8; }
  .big-formula { font-size: 1.5rem; font-weight: 700; color: #1d4ed8; display: block; margin: 8px 0; font-family: 'Courier New', monospace; }
  .formula-box p { margin: 8px 0 0; color: #475569; }
  .example-box { background: #f0fdf4; border: 2px solid #22c55e; border-radius: 12px; padding: 20px; margin: 20px 0; }
  .example-box h4 { color: #15803d; margin: 0 0 12px; }
  .exercise-section { background: #fafbfc; }
  .summary-section { background: linear-gradient(135deg, #ecfdf5 0%, #d1fae5 100%); border: 2px solid #10b981; }
  .summary-section h2 { border-color: #10b981; color: #059669; }
  .summary-grid { display: grid; gap: 12px; }
  .summary-item { display: flex; align-items: center; gap: 12px; font-size: 1rem; }
  .summary-icon { font-size: 1.3rem; }
  .nav-buttons { display: flex; justify-content: space-between; margin-top: 40px; gap: 16px; }
  .nav-btn { flex: 1; display: inline-block; padding: 14px 24px; text-align: center; text-decoration: none; border-radius: 8px; font-weight: 600; transition: all 0.2s; }
  .nav-btn:not(.secondary) { background: #3b82f6; color: white; }
  .nav-btn:not(.secondary):hover { background: #2563eb; }
  .nav-btn.secondary { background: #f1f5f9; color: #475569; }
  .nav-btn.secondary:hover { background: #e2e8f0; }
</style>
