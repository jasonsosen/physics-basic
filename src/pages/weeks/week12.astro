---
import TabView from '../../components/TabView.astro';
import Layout from '../../layouts/Layout.astro';
import QuizCard from '../../components/QuizCard.astro';
import Math from '../../components/Math.astro';
---

<Layout title="Week 12: 鉛直運動">
  <h1>Week 12: 鉛直運動</h1>

  <TabView>
    <!-- ========== 内容タブ ========== -->
    <div slot="content">


  <!-- ===== Section 1: 自由落下 ===== -->
  <section class="content-section">
    <h2>🍎 自由落下</h2>
    
    <div class="intro-box">
      物体から静かに手を放す運動。初速度 <strong>v₀ = 0</strong> で、加速度が <strong>g（重力加速度）</strong> の等加速度運動！<br/>
      （下向きを正とする）
    </div>

    <div class="formula-box">
      <h4>自由落下の公式</h4>
      <Math f="v = gt" block />
      <Math f="h = \\frac{1}{2}gt^2" block />
      <Math f="v^2 = 2gh" block />
      <p>※ 先週の等加速度公式の、v₀=0, a=g, x=h にしただけ！</p>
    </div>
  </section>

  <!-- ===== Section 2: 鉛直投げ上げ ===== -->
  <section class="content-section">
    <h2>⬆️ 鉛直投げ上げ</h2>

    <div class="intro-box">
      真上に物体を投げる運動！ 初速度 <strong>v₀</strong>、加速度は重力に逆らうので <strong>-g</strong> になる。<br/>
      （上向きを正とする）
    </div>

    <div class="formula-box">
      <h4>投げ上げの公式</h4>
      <Math f="v = v_{0} - gt" block />
      <Math f="h = v_{0}t - \\frac{1}{2}gt^2" block />
      <Math f="v^2 - v_{0}^2 = -2gh" block />
    </div>

    <div class="tip-box">
      <strong>💡 重要ポイント（対称性）</strong>
      <ul>
        <li><strong>最高点：</strong> 速度 <strong>v = 0</strong> になる！</li>
        <li><strong>落ちてくる時間：</strong> 行きの時間と帰りの時間は <strong>同じ！</strong></li>
        <li><strong>元の高さでの速度：</strong> 初速度と同じ大きさ（向きは下）</li>
      </ul>
    </div>
  </section>
    </div>

    <!-- ========== 題目タブ ========== -->
    <div slot="problems">

      <!-- 基礎問題 -->
      <section class="content-section exercise-section">
        <h2>✏️ 基礎問題</h2>
        <p class="section-desc">公式の基本を確認しよう</p>
        <QuizCard 
      id="1"
      question="ビルからリンゴを静かに落とした。2秒後の速度 v は？"
      answer="19.6"
      answerUnit="m/s"
      steps={[
        "v = gt",
        "= 9.8 × 2",
        "= <strong>19.6 m/s</strong>"
      ]}
    />

<QuizCard 
      id="2"
      question="問1のとき、2秒間に落下した距離（高さ h）は？"
      answer="19.6"
      answerUnit="m"
      steps={[
        "h = ½gt²",
        "= ½ × 9.8 × 2²",
        "= 4.9 × 4 = <strong>19.6 m</strong>"
      ]}
    />

<QuizCard 
      id="3"
      question="高さ 44.1 m の橋から石を落とした。水面につくまでの時間 t は？"
      answer="3"
      answerUnit="s"
      steps={[
        "h = ½gt²",
        "44.1 = 4.9 × t²",
        "t² = 44.1 / 4.9 = 9",
        "t = <strong>3 s</strong>"
      ]}
    />
      </section>

      <!-- 陷阱問題 -->
      <section class="content-section exercise-section trap-section">
        <h2>🚨 よくある間違い</h2>
        <p class="section-desc">間違えやすい単位換算や概念！</p>
        <QuizCard 
      id="4"
      question="問3の石が水面につく瞬間の速度 v は？"
      answer="29.4"
      answerUnit="m/s"
      steps={[
        "v = gt",
        "= 9.8 × 3 = <strong>29.4 m/s</strong>"
      ]}
    />
      </section>

      <!-- 総合問題 -->
      <section class="content-section exercise-section exam-section">
        <h2>🎓 総合問題</h2>
        <p class="section-desc">試験形式の文字式・総合問題</p>

        <div class="exam-problem">
          <div class="exam-question">
            <strong>【問】</strong> 次の文章を読み、指定された文字を用いて答えなさい。<br/>
            質量 <i>m</i> [kg] の物体に、一定の力 <i>F</i> [N] を加えたときの関係式を記述しなさい。（重力加速度を <i>g</i> とします）
          </div>
          <div class="exam-details">
            (1) 物体にかかる重力を求めよ。<br/>
            (2) 運動方程式を立てよ。
          </div>
          <details class="exam-answer">
            <summary>解答と解説を見る</summary>
            <div class="answer-content">
              <p><strong>解答：</strong></p>
              <p>(1) <i>W = mg</i></p>
              <p>(2) <i>F = ma</i> （<i>a</i> は加速度）</p>
              <p><strong>解説：</strong></p>
              <p>文字式で答える場合は、単位に注意しながら公式をそのまま適用します。</p>
            </div>
          </details>
        </div>
      </section>
    </div>
    </TabView>

  <div class="nav-buttons">
    <a href="/physics-basic/weeks/week11/" class="nav-btn secondary">← Week 11</a>
    <a href="/physics-basic/weeks/week13/" class="nav-btn">Week 13 へ →</a>
  </div>
</Layout>

<style>
  /* Base styles */
  .content-section {
    margin: 40px 0;
    padding: 24px;
    background: #ffffff;
    border-radius: 16px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  }

  .content-section h2 {
    color: #1e293b;
    font-size: 1.5rem;
    margin-bottom: 20px;
    padding-bottom: 12px;
    border-bottom: 3px solid #3b82f6;
  }

  .content-section h3 {
    margin-top: 32px;
    color: #334155;
    border-left: 4px solid #f59e0b;
    padding-left: 12px;
  }

  .intro-box {
    background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
    border-radius: 12px;
    padding: 20px;
    margin-bottom: 24px;
    font-size: 1.05rem;
  }

  .formula-box {
    background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
    border: 2px solid #3b82f6;
    border-radius: 12px;
    padding: 24px;
    text-align: center;
    margin: 24px 0;
  }

  .formula-box h4 {
    margin: 0 0 12px;
    color: #1d4ed8;
  }

  .big-formula {
    font-size: 1.5rem;
    font-weight: 700;
    color: #1d4ed8;
    display: block;
    margin: 8px 0;
    font-family: 'Courier New', monospace;
  }

  .tip-box {
    background: #eff6ff;
    border-left: 4px solid #3b82f6;
    padding: 16px 20px;
    border-radius: 0 8px 8px 0;
    margin: 20px 0;
  }

  .tip-box ul {
    margin: 8px 0 0;
    padding-left: 20px;
  }

  .tip-box li {
    margin-bottom: 4px;
  }

  .exercise-section {
    background: #fafbfc;
  }

  .nav-buttons {
    display: flex;
    justify-content: space-between;
    margin-top: 40px;
    gap: 16px;
  }

  .nav-btn {
    flex: 1;
    display: inline-block;
    padding: 14px 24px;
    text-align: center;
    text-decoration: none;
    border-radius: 8px;
    font-weight: 600;
    transition: all 0.2s;
  }

  .nav-btn:not(.secondary) {
    background: #3b82f6;
    color: white;
  }

  .nav-btn:not(.secondary):hover {
    background: #2563eb;
  }

  .nav-btn.secondary {
    background: #f1f5f9;
    color: #475569;
  }

  .nav-btn.secondary:hover {
    background: #e2e8f0;
  }
</style>
