---
import TabView from '../../components/TabView.astro';
import Layout from '../../layouts/Layout.astro';
import QuizCard from '../../components/QuizCard.astro';
import Math from '../../components/Math.astro';
---

<Layout title="Week 10: 運動方程式">
  <h1>Week 10: 運動方程式</h1>

  <TabView>
    <!-- ========== 内容タブ ========== -->
    <div slot="content">


  <!-- ===== Section 1: 運動方程式 F=ma ===== -->
  <section class="content-section">
    <h2>🚀 運動方程式 F = ma</h2>
    
    <div class="intro-box">
      力を加えると物体は加速する！<br/>
      <strong>力（F）</strong>、<strong>質量（m）</strong>、<strong>加速度（a）</strong>のカンケイ！
    </div>

    <div class="formula-box">
      <Math f="F = ma" block />
      <p>F: 力 [N]、m: 質量 [kg]、a: 加速度 [m/s²]</p>
    </div>

    <div class="simple-cases">
      <div class="case-card">
        <div class="case-text"><strong>加速度を知りたい</strong></div>
        <div class="case-example">a = F / m</div>
        <p>力が大きいほど、質量が小さいほど加速する</p>
      </div>
      <div class="case-card">
        <div class="case-text"><strong>質量を知りたい</strong></div>
        <div class="case-example">m = F / a</div>
      </div>
    </div>
  </section>

  <!-- ===== Section 2: 斜面を滑り降りる運動 ===== -->
  <section class="content-section">
    <h2>⛰️ 斜面を滑り降りる運動</h2>

    <div class="intro-box">
      摩擦がない斜面を物体が滑り降りるとき、運動させる力は<strong>重力の斜面下向き成分</strong>！
    </div>

    <div class="formula-box">
      <Math f="滑る力：F = mg sin \\theta" block />
      <Math f="加速度：a = g sin \\theta" block />
      <p>※ 運動方程式 $ma = mg \sin \theta$ より、$m$が消える！つまり質量に関係なく加速度は同じ。</p>
    </div>
  </section>
    </div>

    <!-- ========== 題目タブ ========== -->
    <div slot="problems">

      <!-- 基礎問題 -->
      <section class="content-section exercise-section">
        <h2>✏️ 基礎問題</h2>
        <p class="section-desc">公式の基本を確認しよう</p>
        <QuizCard 
      id="1"
      question="質量 2000 g の物体に 10 N の力を加えた。加速度は？"
      answer="5.0"
      answerUnit="m/s²"
      steps={[
        "F = ma より、a = F / m",
        "= 10 / 2.0 = <strong>5.0 m/s²</strong>"
      ]}
    />

<QuizCard 
      id="2"
      question="質量 5.0 kg の物体が 3.0 m/s² で加速している。加わっている力は？"
      answer="15"
      answerUnit="N"
      steps={[
        "F = ma",
        "= 5.0 × 3.0 = <strong>15 N</strong>"
      ]}
    />

<QuizCard 
      id="3"
      question="物体に 20 N の力を加えると 4.0 m/s² で加速した。物体の質量は？"
      answer="5.0"
      answerUnit="kg"
      steps={[
        "F = ma より、m = F / a",
        "= 20 / 4.0 = <strong>5.0 kg</strong>"
      ]}
    />
      </section>

      <!-- 陷阱問題 -->
      <section class="content-section exercise-section trap-section">
        <h2>🚨 よくある間違い</h2>
        <p class="section-desc">間違えやすい単位換算や概念！</p>
        <QuizCard 
      id="4"
      question="右向きに 15 N、左向きに 5 N の力が加わっている質量 2000 g の物体の加速度は？"
      answer="5.0"
      answerUnit="m/s²"
      steps={[
        "合力 F = 15 - 5 = 10 N",
        "a = F / m = 10 / 2.0 = <strong>5.0 m/s²</strong>（右向き）"
      ]}
    />
      </section>

      <!-- 総合問題 -->
      <section class="content-section exam-section">
        <h2>📝 総合問題（試験形式）</h2>
        <p class="section-desc">文字式で答える練習。期末試験はこの形式！</p>

        <div class="exam-problem">
          <div class="problem-header">
            <span class="problem-num">総合1</span>
            <span class="problem-topic">斜面上の運動方程式</span>
          </div>
          <div class="problem-body">
            <p>傾角 <Math f="\\theta" /> のあらい斜面上を、質量 <Math f="m" /> [kg] の物体が下に向かって滑り落ちている。動摩擦係数を <Math f="\\mu'" />、重力加速度を <Math f="g" /> [m/s²] とする。</p>
            <div class="problem-questions">
              <p><strong>(1)</strong> 斜面に垂直な方向の力のつり合いの式を書き、垂直抗力 <Math f="N" /> を求めなさい。</p>
              <p><strong>(2)</strong> 斜面に平行な下向きを正として、物体の加速度を <Math f="a" /> [m/s²] としたときの運動方程式を書きなさい。</p>
              <p><strong>(3)</strong> 加速度 <Math f="a" /> を <Math f="g, \\theta, \\mu'" /> で表しなさい。</p>
            </div>
          </div>
          <details class="solution-details">
            <summary>💡 解答を見る</summary>
            <div class="solution-content">
              <p><strong>(1)</strong> <Math f="N - mg \\cos \\theta = 0" /> より、<Math f="N = mg \\cos \\theta" /></p>
              <p><strong>(2)</strong> 動摩擦力は上向きに <Math f="\\mu' N" /> はたらく。</p>
              <p class="indent"><Math f="\\boxed{ma = mg \\sin \\theta - \\mu' N}" /></p>
              <p><strong>(3)</strong> (1) の <Math f="N" /> を (2) に代入すると、</p>
              <p class="indent"><Math f="ma = mg \\sin \\theta - \\mu' mg \\cos \\theta" /></p>
              <p class="indent"><Math f="\\boxed{a = g(\\sin \\theta - \\mu' \\cos \\theta)}" /></p>
            </div>
          </details>
        </div>
        
      </section>
    </div>
    </TabView>

  <div class="nav-buttons">
    <a href="/physics-basic/weeks/week09/" class="nav-btn secondary">← Week 9</a>
    <a href="/physics-basic/weeks/week11/" class="nav-btn">Week 11 へ →</a>
  </div>
</Layout>

<style>
  /* Base styles */
  .content-section {
    margin: 40px 0;
    padding: 24px;
    background: #ffffff;
    border-radius: 16px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  }

  .content-section h2 {
    color: #1e293b;
    font-size: 1.5rem;
    margin-bottom: 20px;
    padding-bottom: 12px;
    border-bottom: 3px solid #3b82f6;
  }

  .intro-box {
    background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
    border-radius: 12px;
    padding: 20px;
    margin-bottom: 24px;
    font-size: 1.05rem;
  }

  .formula-box {
    background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
    border: 2px solid #3b82f6;
    border-radius: 12px;
    padding: 24px;
    text-align: center;
    margin: 24px 0;
  }

  .big-formula {
    font-size: 1.5rem;
    font-weight: 700;
    color: #1d4ed8;
    display: block;
    margin: 8px 0;
    font-family: 'Courier New', monospace;
  }

  .simple-cases {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 16px;
    margin: 20px 0;
  }

  .case-card {
    background: #f8fafc;
    border: 2px solid #e2e8f0;
    border-radius: 12px;
    padding: 16px;
    text-align: center;
  }

  .case-example {
    font-size: 1.2rem;
    font-weight: bold;
    color: #059669;
    margin: 8px 0;
  }

  .exercise-section {
    background: #fafbfc;
  }

  .nav-buttons {
    display: flex;
    justify-content: space-between;
    margin-top: 40px;
    gap: 16px;
  }

  .nav-btn {
    flex: 1;
    display: inline-block;
    padding: 14px 24px;
    text-align: center;
    text-decoration: none;
    border-radius: 8px;
    font-weight: 600;
    transition: all 0.2s;
  }

  .nav-btn:not(.secondary) {
    background: #3b82f6;
    color: white;
  }

  .nav-btn:not(.secondary):hover {
    background: #2563eb;
  }

  .nav-btn.secondary {
    background: #f1f5f9;
    color: #475569;
  }

  .nav-btn.secondary:hover {
    background: #e2e8f0;
  }
</style>
