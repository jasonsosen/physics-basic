---
import TabView from '../../components/TabView.astro';
import VectorAdder from "../../components/VectorAdder.astro";
import Layout from '../../layouts/Layout.astro';
import QuizCard from '../../components/QuizCard.astro';
import Math from '../../components/Math.astro';
---

<Layout title="Week 4: 力の合成と分解">
  <h1>Week 4: 力の合成と分解</h1>

  <TabView>
    <!-- ========== 内容タブ ========== -->
    <div slot="content">


  <!-- ===== Section 1: ベクトルの基礎 ===== -->
  <section class="content-section">
    <h2>➡️ 力はベクトル！</h2>
    
    <div class="intro-box">
      力には <strong>大きさ</strong> と <strong>向き</strong> がある → 矢印（ベクトル）で表す
    </div>

    <div class="vector-notation">
      <h3>ベクトルの表し方</h3>
      <div class="notation-cards">
        <div class="notation-card">
          <div class="notation-title">成分表示</div>
          <div class="notation-example">F = (Fx, Fy)</div>
          <div class="notation-desc">例：F = (3.0, 4.0) N</div>
        </div>
        <div class="notation-card">
          <div class="notation-title">大きさと角度</div>
          <div class="notation-example">|F|, θ</div>
          <div class="notation-desc">例：5.0 N, 53°</div>
        </div>
      </div>
    </div>

    <div class="formula-box">
      <h4>大きさの求め方（三平方の定理）</h4>
      <Math f="|F| = \\sqrt{F_x^2 + F_y^2}" block />
    </div>
  </section>

  <!-- ===== Section 2: 力の合成 ===== -->
  <section class="content-section">
    <h2>➕ 力の合成（合力）</h2>

    <h3>一直線上の力</h3>
    <div class="simple-cases">
      <div class="case-card">
        <div class="case-icon">→ →</div>
        <div class="case-text"><strong>同じ向き：</strong>足し算</div>
        <div class="case-example">3 N + 4 N = 7 N</div>
      </div>
      <div class="case-card">
        <div class="case-icon">→ ←</div>
        <div class="case-text"><strong>逆向き：</strong>引き算</div>
        <div class="case-example">5 N - 2 N = 3 N</div>
      </div>
    </div>

    <h3>斜めの力：成分ごとに足す</h3>
    <div class="formula-box">
      <Math f="F = F_{1} + F_{2} = (F_{1}x + F_{2}x, F_{1}y + F_{2}y)" block />
    </div>

    <div class="example-box">
      <h4>例：2つのベクトルの合成</h4>
      <p>F₁ = (5.0, 0.0) N、F₂ = (-2.0, 4.0) N</p>
      <div class="solution-steps">
        <p>F = F₁ + F₂ = (5.0 + (-2.0), 0.0 + 4.0) = <strong>(3.0, 4.0) N</strong></p>
        <p>|F| = √(3² + 4²) = √25 = <strong>5.0 N</strong></p>
      </div>
    </div>

    <h3>🎮 ベクトル合成シミュレーター</h3>
    <div class="animation-container" id="vector-animation">
      <canvas id="vectorCanvas" width="400" height="300"></canvas>
      <p class="canvas-hint">赤と青の矢印の先端をドラッグして動かしてみよう！</p>
    </div>
  </section>

  <!-- ===== Section 4: 力の分解 ===== -->
  <section class="content-section">
    <h2>➗ 力の分解（分力）</h2>

    <div class="intro-box">
      1つの力を、<strong>2つの方向（x と y）</strong>に分ける！
    </div>

    <div class="formula-box">
      <Math f="Fx = F cos \\theta" block />
      <Math f="Fy = F sin \\theta" block />
      <p>θ は x軸（水平）からの角度</p>
    </div>

    <div class="trig-memory">
      <h4>💡 sin・cos の覚え方</h4>
      <div class="memory-cards">
        <div class="memory-card">
          <div class="memory-fn">cos θ</div>
          <div class="memory-hint">→ 地面に落ちた影（横方向）</div>
        </div>
        <div class="memory-card">
          <div class="memory-fn">sin θ</div>
          <div class="memory-hint">↑ 壁に映った影（縦方向）</div>
        </div>
      </div>
    </div>

    <h3>三角関数の値（暗記！）</h3>
    <div class="trig-table">
      <table>
        <tr><th>角度 θ</th><th>sin θ</th><th>cos θ</th></tr>
        <tr><td>0°</td><td>0</td><td>1</td></tr>
        <tr><td>30°</td><td>1/2 = 0.5</td><td>√3/2 ≈ 0.87</td></tr>
        <tr><td>45°</td><td>√2/2 ≈ 0.71</td><td>√2/2 ≈ 0.71</td></tr>
        <tr><td>60°</td><td>√3/2 ≈ 0.87</td><td>1/2 = 0.5</td></tr>
        <tr><td>90°</td><td>1</td><td>0</td></tr>
        <tr class="highlight-row"><td>120°</td><td>√3/2 ≈ 0.87</td><td><strong>-1/2 = -0.5</strong></td></tr>
      </table>
    </div>

    <div class="warning-box">
      <strong>⚠️ 注意：90°を超えると cos が負になる！</strong><br/>
      cos 120° = -0.5（x成分が負＝左向き）
    </div>
  </section>

  <!-- ===== Section 6: 斜面上の物体 ===== -->
  <section class="content-section">
    <h2>⛰️ 斜面上の物体</h2>

    <div class="intro-box">
      重力 mg を斜面に沿って分解すると...
    </div>

    <div class="incline-diagram">
      <div class="incline-visual">
        <div class="incline-slope"></div>
        <div class="incline-object">📦</div>
        <div class="incline-angle">θ</div>
        <div class="force-parallel">mg sin θ</div>
        <div class="force-perp">mg cos θ</div>
      </div>
    </div>

    <div class="incline-table">
      <table>
        <tr><th>成分</th><th>公式</th><th>意味</th></tr>
        <tr>
          <td>斜面に平行 ↘</td>
          <td><strong>mg sin θ</strong></td>
          <td>滑り落ちる力</td>
        </tr>
        <tr>
          <td>斜面に垂直 ↗</td>
          <td><strong>mg cos θ</strong></td>
          <td>面を押す力（垂直抗力と釣り合う）</td>
        </tr>
      </table>
    </div>

    <div class="tip-box">
      <strong>💡 覚え方</strong>
      <p>斜面角度が大きくなると → <strong>滑る力 (sin θ) が増える</strong></p>
      <p>θ = 90° なら自由落下（全部滑る力）、θ = 0° なら水平（滑らない）</p>
    </div>
  </section>

  <!-- ===== Section 8: 力のつり合い ===== -->
  <section class="content-section">
    <h2>⚖️ 力のつり合い</h2>

    <div class="formula-box">
      <Math f="\\Sigma F_x = 0, \\quad \\Sigma F_y = 0" block />
      <p>静止している物体は、力がつり合っている！</p>
    </div>

    <div class="equilibrium-example">
      <h4>例：3つの力のつり合い</h4>
      <p>F₁ + F₂ + F₃ = 0 のとき、F₃ を求める</p>
      <div class="solution-steps">
        <p>F₁ = (3, 0) N、F₂ = (0, 4) N とすると...</p>
        <p>F₃ = -(F₁ + F₂) = -((3, 4)) = <strong>(-3, -4) N</strong></p>
      </div>
    </div>
  </section>

  <!-- ===== Section 10: まとめ ===== -->
  <section class="content-section summary-section">
    <h2>📝 今日のまとめ</h2>
    <div class="summary-grid">
      <div class="summary-item">
        <span class="summary-icon">➕</span>
        <span>合力：<strong>成分ごとに足す</strong> F = (F₁x+F₂x, F₁y+F₂y)</span>
      </div>
      <div class="summary-item">
        <span class="summary-icon">📐</span>
        <span>大きさ：<strong>|F| = √(Fx² + Fy²)</strong></span>
      </div>
      <div class="summary-item">
        <span class="summary-icon">➗</span>
        <span>分解：<strong>Fx = F cos θ、Fy = F sin θ</strong></span>
      </div>
      <div class="summary-item">
        <span class="summary-icon">⛰️</span>
        <span>斜面：滑る力 = <strong>mg sin θ</strong></span>
      </div>
      <div class="summary-item">
        <span class="summary-icon">⚖️</span>
        <span>つり合い：<strong>ΣFx = 0、ΣFy = 0</strong></span>
      </div>
      <div class="summary-item warning">
        <span class="summary-icon">⚠️</span>
        <span>90°超え → <strong>cos が負になる</strong></span>
      </div>
    </div>
  </section>
    </div>

    <!-- ========== 題目タブ ========== -->
    <div slot="problems">

      <!-- 基礎問題 -->
      <section class="content-section exercise-section">
        <h2>✏️ 基礎問題</h2>
        <p class="section-desc">公式の基本を確認しよう</p>
        <QuizCard 
      id="1"
      question="F₁ = (5.0, 0.0) N の大きさ"
      answer="5.0"
      answerUnit="N"
      steps={[
        "|F₁| = √(5.0² + 0²)",
        "= √25 = <strong>5.0 N</strong>"
      ]}
    />

<QuizCard 
      id="2"
      question="F₁ = (5.0, 0.0) N と F₂ = (-2.0, 4.0) N の合力"
      answer="(3.0, 4.0)"
      answerUnit="N"
      steps={[
        "F = F₁ + F₂",
        "Fx = 5.0 + (-2.0) = 3.0",
        "Fy = 0.0 + 4.0 = 4.0",
        "F = <strong>(3.0, 4.0) N</strong>"
      ]}
    />

<QuizCard 
      id="3"
      question="問2の合力の大きさ"
      answer="5.0"
      answerUnit="N"
      steps={[
        "|F| = √(3.0² + 4.0²)",
        "= √(9 + 16) = √25",
        "= <strong>5.0 N</strong>"
      ]}
      hint="3-4-5の直角三角形！"
    />
      </section>

      <!-- 陷阱問題 -->
      <section class="content-section exercise-section trap-section">
        <h2>🚨 よくある間違い</h2>
        <p class="section-desc">間違えやすい単位換算や概念！</p>
        <QuizCard 
      id="4"
      question="F₁ = (6.0, 2.0) N と F₂ = (-4.0, 6.0) N の合力の大きさ"
      answer="10"
      answerUnit="N"
      steps={[
        "F = (6.0-4.0, 2.0+6.0) = (2.0, 8.0)",
        "|F| = √(2² + 8²) = √(4 + 64)",
        "= √68 ≈ <strong>8.2 N</strong>"
      ]}
    />
      </section>

      <!-- 総合問題 -->
      <section class="content-section exam-section">
        <h2>📝 総合問題（試験形式）</h2>
        <p class="section-desc">文字式で答える練習。期末試験はこの形式！</p>

        <div class="exam-problem">
          <div class="problem-header">
            <span class="problem-num">総合1</span>
            <span class="problem-topic">斜面上の力のつり合い</span>
          </div>
          <div class="problem-body">
            <p>傾角 <Math f="\\theta" /> のなめらかな斜面上に、質量 <Math f="m" /> [kg] の物体を置き、斜面に平行な上向きに力 <Math f="F" /> [N] を加えて静止させた。重力加速度を <Math f="g" /> [m/s²] とする。</p>
            <div class="problem-questions">
              <p><strong>(1)</strong> 物体にはたらく力のつり合いの式を、斜面に平行な方向と垂直な方向についてそれぞれ書きなさい。（垂直抗力を <Math f="N" /> [N] とする）</p>
              <p><strong>(2)</strong> 力 <Math f="F" /> および 垂直抗力 <Math f="N" /> を <Math f="m, g, \\theta" /> を用いて表しなさい。</p>
            </div>
          </div>
          <details class="solution-details">
            <summary>💡 解答を見る</summary>
            <div class="solution-content">
              <p><strong>(1)</strong></p>
              <p class="indent">斜面に平行な方向: <Math f="F - mg \\sin \\theta = 0" /></p>
              <p class="indent">斜面に垂直な方向: <Math f="N - mg \\cos \\theta = 0" /></p>
              <p><strong>(2)</strong> 上記のつり合いの式より、</p>
              <p class="indent"><Math f="\\boxed{F = mg \\sin \\theta}" /></p>
              <p class="indent"><Math f="\\boxed{N = mg \\cos \\theta}" /></p>
            </div>
          </details>
        </div>
        
      </section>
    </div>
    </TabView>

  <div class="nav-buttons">
    <a href="/physics-basic/weeks/week03/" class="nav-btn secondary">← Week 3</a>
    <a href="/physics-basic/weeks/week05/" class="nav-btn">Week 5 へ →</a>
  </div>
</Layout>

<style>
  /* ===== 基本スタイル ===== */
  .content-section {
    margin: 40px 0;
    padding: 24px;
    background: #ffffff;
    border-radius: 16px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  }

  .content-section h2 {
    color: #1e293b;
    font-size: 1.5rem;
    margin-bottom: 20px;
    padding-bottom: 12px;
    border-bottom: 3px solid #3b82f6;
  }

  .intro-box {
    background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
    border-radius: 12px;
    padding: 20px;
    margin-bottom: 24px;
    font-size: 1.05rem;
  }

  /* ===== 公式ボックス ===== */
  .formula-box {
    background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
    border: 2px solid #3b82f6;
    border-radius: 12px;
    padding: 24px;
    text-align: center;
    margin: 24px 0;
  }

  .formula-box h4 {
    margin: 0 0 12px;
    color: #1d4ed8;
  }

  .big-formula {
    font-size: 1.5rem;
    font-weight: 700;
    color: #1d4ed8;
    display: block;
    margin: 8px 0;
    font-family: 'Courier New', monospace;
  }

  .formula-box p {
    margin: 8px 0 0;
    color: #475569;
  }

  /* ===== ベクトル表記 ===== */
  .notation-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 16px;
    margin: 16px 0;
  }

  .notation-card {
    background: #f8fafc;
    border: 2px solid #e2e8f0;
    border-radius: 12px;
    padding: 16px;
    text-align: center;
  }

  .notation-title {
    font-weight: 600;
    color: #64748b;
    font-size: 0.9rem;
  }

  .notation-example {
    font-size: 1.3rem;
    font-weight: 700;
    color: #1d4ed8;
    margin: 8px 0;
    font-family: 'Courier New', monospace;
  }

  .notation-desc {
    font-size: 0.85rem;
    color: #94a3b8;
  }

  /* ===== 一直線上の力 ===== */
  .simple-cases {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 16px;
    margin: 20px 0;
  }

  .case-card {
    background: #f8fafc;
    border: 2px solid #e2e8f0;
    border-radius: 12px;
    padding: 16px;
    text-align: center;
  }

  .case-icon {
    font-size: 1.5rem;
    margin-bottom: 8px;
  }

  .case-example {
    font-family: 'Courier New', monospace;
    color: #059669;
    font-weight: 600;
    margin-top: 8px;
  }

  /* ===== 例題ボックス ===== */
  .example-box {
    background: #f0fdf4;
    border: 2px solid #22c55e;
    border-radius: 12px;
    padding: 20px;
    margin: 20px 0;
  }

  .example-box h4 {
    color: #15803d;
    margin: 0 0 12px;
  }

  .solution-steps {
    background: white;
    padding: 12px 16px;
    border-radius: 8px;
    margin-top: 12px;
  }

  .solution-steps p {
    margin: 6px 0;
    font-family: 'Courier New', monospace;
  }

  /* ===== キャンバス ===== */
  .animation-container {
    text-align: center;
    margin: 24px 0;
  }

  #vectorCanvas {
    border: 2px solid #e2e8f0;
    border-radius: 12px;
    background: white;
    cursor: crosshair;
    max-width: 100%;
  }

  .canvas-hint {
    font-size: 0.9rem;
    color: #64748b;
    margin-top: 8px;
  }

  /* ===== 三角関数 ===== */
  .trig-memory {
    margin: 24px 0;
  }

  .memory-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 16px;
    margin-top: 12px;
  }

  .memory-card {
    background: #fef3c7;
    border: 2px solid #f59e0b;
    border-radius: 12px;
    padding: 16px;
    text-align: center;
  }

  .memory-fn {
    font-size: 1.2rem;
    font-weight: 700;
    color: #d97706;
    font-family: 'Courier New', monospace;
  }

