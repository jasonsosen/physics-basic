  }

  .trig-table th {
    background: #f1f5f9;
    font-weight: 600;
  }

  .highlight-row {
    background: #fef3c7 !important;
  }

  .highlight-row td {
    font-weight: 600;
  }

  /* ===== 警告ボックス ===== */
  .warning-box {
    background: #fef2f2;
    border: 2px solid #ef4444;
    border-radius: 12px;
    padding: 16px 20px;
    margin: 20px 0;
    color: #991b1b;
  }

  /* ===== 斜面 ===== */
  .incline-diagram {
    margin: 24px 0;
    padding: 20px;
    background: #f8fafc;
    border-radius: 12px;
    text-align: center;
  }

  .incline-table table {
    width: 100%;
    border-collapse: collapse;
    margin: 16px 0;
  }

  .incline-table th, .incline-table td {
    padding: 12px;
    border: 1px solid #e2e8f0;
    text-align: center;
  }

  .incline-table th {
    background: #f1f5f9;
  }

  /* ===== ヒント ===== */
  .tip-box {
    background: #eff6ff;
    border-left: 4px solid #3b82f6;
    padding: 16px 20px;
    border-radius: 0 8px 8px 0;
    margin: 20px 0;
  }

  .tip-box p {
    margin: 6px 0;
  }

  /* ===== つり合い例 ===== */
  .equilibrium-example {
    background: #f0fdf4;
    border: 2px solid #22c55e;
    border-radius: 12px;
    padding: 20px;
    margin: 20px 0;
  }

  .equilibrium-example h4 {
    color: #15803d;
    margin: 0 0 12px;
  }

  /* ===== 練習セクション ===== */
  .exercise-section {
    background: #fafbfc;
  }

  /* ===== まとめ ===== */
  .summary-section {
    background: linear-gradient(135deg, #ecfdf5 0%, #d1fae5 100%);
    border: 2px solid #10b981;
  }

  .summary-section h2 {
    border-color: #10b981;
    color: #059669;
  }

  .summary-grid {
    display: grid;
    gap: 12px;
  }

  .summary-item {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 1rem;
  }

  .summary-item.warning {
    color: #dc2626;
    font-weight: 600;
  }

  .summary-icon {
    font-size: 1.3rem;
  }

  /* ===== ナビゲーション ===== */
  .nav-buttons {
    display: flex;
    justify-content: space-between;
    margin-top: 40px;
    gap: 16px;
  }

  .nav-btn {
    flex: 1;
    display: inline-block;
    padding: 14px 24px;
    text-align: center;
    text-decoration: none;
    border-radius: 8px;
    font-weight: 600;
    transition: all 0.2s;
  }

  .nav-btn:not(.secondary) {
    background: #3b82f6;
    color: white;
  }

  .nav-btn:not(.secondary):hover {
    background: #2563eb;
  }

  .nav-btn.secondary {
    background: #f1f5f9;
    color: #475569;
  }

  .nav-btn.secondary:hover {
    background: #e2e8f0;
  }
</style>

<script>
  // Vector animation
  const canvas = document.getElementById('vectorCanvas') as HTMLCanvasElement;
  if (canvas) {
    const ctx = canvas.getContext('2d');
    const origin = { x: 200, y: 200 };
    let vecA = { x: 80, y: -60 };
    let vecB = { x: 100, y: 40 };
    let dragging: string | null = null;

    function draw() {
      if (!ctx) return;
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      
      // Grid
      ctx.strokeStyle = '#e2e8f0';
      ctx.lineWidth = 1;
      for (let i = 0; i < canvas.width; i += 20) {
        ctx.beginPath();
        ctx.moveTo(i, 0);
        ctx.lineTo(i, canvas.height);
        ctx.stroke();
      }
      for (let i = 0; i < canvas.height; i += 20) {
        ctx.beginPath();
        ctx.moveTo(0, i);
        ctx.lineTo(canvas.width, i);
        ctx.stroke();
      }

      // Parallelogram (dotted)
      ctx.strokeStyle = '#94a3b8';
      ctx.setLineDash([5, 5]);
      ctx.beginPath();
      ctx.moveTo(origin.x + vecA.x, origin.y + vecA.y);
      ctx.lineTo(origin.x + vecA.x + vecB.x, origin.y + vecA.y + vecB.y);
      ctx.lineTo(origin.x + vecB.x, origin.y + vecB.y);
      ctx.stroke();
      ctx.setLineDash([]);

      // Vector A (red)
      drawArrow(ctx, origin.x, origin.y, origin.x + vecA.x, origin.y + vecA.y, '#ef4444', 3);
      
      // Vector B (blue)
      drawArrow(ctx, origin.x, origin.y, origin.x + vecB.x, origin.y + vecB.y, '#3b82f6', 3);
      
      // Resultant (green)
      const resultX = vecA.x + vecB.x;
      const resultY = vecA.y + vecB.y;
      drawArrow(ctx, origin.x, origin.y, origin.x + resultX, origin.y + resultY, '#22c55e', 4);

      // Labels
      ctx.font = 'bold 14px sans-serif';
      ctx.fillStyle = '#ef4444';
      ctx.fillText('F₁', origin.x + vecA.x + 5, origin.y + vecA.y);
      ctx.fillStyle = '#3b82f6';
      ctx.fillText('F₂', origin.x + vecB.x + 5, origin.y + vecB.y);
      ctx.fillStyle = '#22c55e';
      ctx.fillText('合力', origin.x + resultX + 5, origin.y + resultY);

      // Magnitude
      const mag = (Math.sqrt(resultX * resultX + resultY * resultY) / 20).toFixed(1);
      ctx.fillStyle = '#1e293b';
      ctx.fillText(`|合力| ≈ ${mag} 単位`, 10, 20);
    }

    function drawArrow(ctx: CanvasRenderingContext2D, x1: number, y1: number, x2: number, y2: number, color: string, width: number) {
      const headLen = 12;
      const angle = Math.atan2(y2 - y1, x2 - x1);
      
      ctx.strokeStyle = color;
      ctx.fillStyle = color;
      ctx.lineWidth = width;
      
      ctx.beginPath();
      ctx.moveTo(x1, y1);
      ctx.lineTo(x2, y2);
      ctx.stroke();
      
      ctx.beginPath();
      ctx.moveTo(x2, y2);
      ctx.lineTo(x2 - headLen * Math.cos(angle - Math.PI / 6), y2 - headLen * Math.sin(angle - Math.PI / 6));
      ctx.lineTo(x2 - headLen * Math.cos(angle + Math.PI / 6), y2 - headLen * Math.sin(angle + Math.PI / 6));
      ctx.closePath();
      ctx.fill();
    }

    canvas.addEventListener('mousedown', (e) => {
      const rect = canvas.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      
      const distA = Math.hypot(x - (origin.x + vecA.x), y - (origin.y + vecA.y));
      const distB = Math.hypot(x - (origin.x + vecB.x), y - (origin.y + vecB.y));
      
      if (distA < 20) dragging = 'A';
      else if (distB < 20) dragging = 'B';
    });

    canvas.addEventListener('mousemove', (e) => {
      if (!dragging) return;
      const rect = canvas.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      
      if (dragging === 'A') {
        vecA = { x: x - origin.x, y: y - origin.y };
      } else if (dragging === 'B') {
        vecB = { x: x - origin.x, y: y - origin.y };
      }
      draw();
    });

    canvas.addEventListener('mouseup', () => { dragging = null; });
    canvas.addEventListener('mouseleave', () => { dragging = null; });

    draw();
  }

  // Quiz interaction
  document.addEventListener('DOMContentLoaded', () => {
    const cards = document.querySelectorAll('.quiz-card');
    cards.forEach(card => {
      const input = card.querySelector('.quiz-input') as HTMLInputElement;
      const btn = card.querySelector('.quiz-btn') as HTMLButtonElement;
      const solution = card.querySelector('.quiz-solution') as HTMLDivElement;
      
      const showAnswer = () => {
        solution.classList.remove('hidden');
        input.disabled = true;
        btn.disabled = true;
        btn.textContent = '回答済み';
        card.classList.add('answered');
        solution.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      };

      btn.addEventListener('click', showAnswer);
      input.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') {
          e.preventDefault();
          showAnswer();
        }
      });
    });
  });
</script>
