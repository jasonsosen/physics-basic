        "g → kg: × 10⁻³",
        "cm → m: × 10⁻²",
        "1.0 × 10² × 10⁻³ × 10⁻² = 1.0 × 10² × 10⁻⁵",
        "= <strong>1.0 × 10⁻³ N</strong>"
      ]}
      hint="1 dyn (ダイン) = 10⁻⁵ N"
    />
  </section>

