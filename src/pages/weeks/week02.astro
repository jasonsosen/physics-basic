    <p class="section-desc">単位換算を使った実践問題！まず単位を揃えてから計算</p>

    <QuizCard 
      id="16"
      question="直方体（5 mm × 1 cm × 2×10⁻³ m）の体積"
      answer="100"
      answerUnit="mm³"
      steps={[
        "まず全部 mm に統一する",
        "5 mm = 5 mm ✓",
        "1 cm = 10 mm",
        "2×10⁻³ m = 2 mm",
        "体積 = 5 × 10 × 2 = <strong>100 mm³</strong>"
      ]}
      hint="単位を揃えてから掛け算！"
    />

    <QuizCard 
      id="17"
      question="円柱（体積 2 cm³、高さ 50 mm）の断面積"
      answer="40"
      answerUnit="mm²"
      steps={[
        "V = S × h より、S = V / h",
        "単位を mm に統一：",
        "2 cm³ = 2 × 10³ mm³ = 2000 mm³",
        "50 mm = 50 mm",
        "S = 2000 ÷ 50 = <strong>40 mm²</strong>"
      ]}
      hint="体積 = 断面積 × 高さ"
    />

