---
import Layout from '../../layouts/Layout.astro';

const weekData = {
  '03': { title: '力と質量、密度', prev: '02', next: '04' },
  '04': { title: '力の合成と分解', prev: '03', next: '05' },
  '05': { title: '抗力と摩擦力', prev: '04', next: '06' },
  '06': { title: '張力と弾性力', prev: '05', next: '07' },
  '07': { title: '剛体と重心', prev: '06', next: '08' },
  '08': { title: '力のモーメント', prev: '07', next: '09' },
  '09': { title: '運動の表し方', prev: '08', next: '10' },
  '10': { title: '運動方程式', prev: '09', next: '11' },
  '11': { title: '等速度・等加速度運動', prev: '10', next: '12' },
  '12': { title: '落下運動と放物運動', prev: '11', next: null },
};

const weekNum = '11';
const data = weekData[weekNum];
---

<Layout title={`Week ${weekNum}: ${data.title}`}>
  <h1>Week {weekNum}: {data.title}</h1>
  
  <div class="highlight-box">
    <p>🚧 このページは準備中です...</p>
  </div>

  <div class="nav-buttons">
    <a href={`/physics-basic/weeks/week${data.prev}/`} class="nav-btn secondary">← 前へ</a>
    {data.next && (
      <a href={`/physics-basic/weeks/week${data.next}/`} class="nav-btn">次へ →</a>
    )}
  </div>
</Layout>
