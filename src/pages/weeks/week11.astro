---
import TabView from '../../components/TabView.astro';
import Layout from '../../layouts/Layout.astro';
import QuizCard from '../../components/QuizCard.astro';
import Math from '../../components/Math.astro';
---

<Layout title="Week 11: 等速度運動と等加速度運動">
  <h1>Week 11: 等速度運動と等加速度運動</h1>

  <TabView>
    <!-- ========== 内容タブ ========== -->
    <div slot="content">


  <!-- ===== Section 1: 等速直線運動 ===== -->
  <section class="content-section">
    <h2>➡️ 等速直線運動</h2>
    
    <div class="intro-box">
      速度がずっと変わらない（一定の）運動！
    </div>

    <div class="formula-box">
      <h4>位置の公式</h4>
      <Math f="x = x_{0} + vt" block />
      <p>x₀: 初期位置（t=0のときの位置）、v: 速度、t: 時間</p>
    </div>
  </section>

  <!-- ===== Section 2: 等加速度直線運動 ===== -->
  <section class="content-section">
    <h2>🚀 等加速度直線運動</h2>

    <div class="intro-box">
      加速度が一定（少しずつ速くなる or 遅くなる）運動！<br/>
      物理で一番大事な <strong>3つの公式</strong> を覚えよう！
    </div>

    <div class="formula-box">
      <h4>🔥 等加速度 3大公式</h4>
      <p>① 速度と時間の関係（vを知りたい）</p>
      <Math f="v = v_{0} + at" block />
      <hr style="border:0; border-top:1px solid #bfdbfe; margin:16px 0;">
      <p>② 位置と時間の関係（xを知りたい）</p>
      <Math f="x = v_{0}t + \\frac{1}{2}at^2" block />
      <hr style="border:0; border-top:1px solid #bfdbfe; margin:16px 0;">
      <p>③ 時間 t が分からないとき（vとxの関係）</p>
      <Math f="v^2 - v_{0}^2 = 2ax" block />
      
      <div style="margin-top: 16px; text-align: left; background: white; padding: 12px; border-radius: 8px;">
        <p><strong>v₀</strong>: 初速度（最初のスピード）</p>
        <p><strong>v</strong>: t 秒後の速度</p>
        <p><strong>a</strong>: 加速度</p>
        <p><strong>t</strong>: 時間</p>
        <p><strong>x</strong>: 変位（進んだ距離）</p>
      </div>
    </div>
  </section>
    </div>

    <!-- ========== 題目タブ ========== -->
    <div slot="problems">

      <!-- 基礎問題 -->
      <section class="content-section exercise-section">
        <h2>✏️ 基礎問題</h2>
        <p class="section-desc">公式の基本を確認しよう</p>
        <QuizCard 
      id="1"
      question="初めの位置 x₀=5 m から、速度 3 m/s で等速直線運動をした。4秒後の位置 x は？"
      answer="17"
      answerUnit="m"
      steps={[
        "x = x₀ + vt",
        "= 5 + 3 × 4",
        "= 5 + 12 = <strong>17 m</strong>"
      ]}
    />

<QuizCard 
      id="2"
      question="原点(x₀=0)から等速で進み、5秒後に x=20 m に到達した。速度 v は？"
      answer="4"
      answerUnit="m/s"
      steps={[
        "x = vt より、20 = v × 5",
        "v = 20 / 5 = <strong>4 m/s</strong>"
      ]}
    />

<QuizCard 
      id="3"
      question="初速度 2 m/s、加速度 3 m/s² のとき、4秒後の速度 v は？"
      answer="14"
      answerUnit="m/s"
      steps={[
        "v = v₀ + at",
        "= 2 + 3 × 4",
        "= 2 + 12 = <strong>14 m/s</strong>"
      ]}
    />
      </section>

      <!-- 陷阱問題 -->
      <section class="content-section exercise-section trap-section">
        <h2>🚨 よくある間違い</h2>
        <p class="section-desc">間違えやすい単位換算や概念！</p>
        <QuizCard 
      id="4"
      question="静止していた物体（v₀=0）が加速度 5 m/s² で動き出した。3秒後の速度は？"
      answer="15"
      answerUnit="m/s"
      steps={[
        "v = 0 + 5 × 3",
        "= <strong>15 m/s</strong>"
      ]}
    />
      </section>

      <!-- 総合問題 -->
      <section class="content-section exam-section">
        <h2>📝 総合問題（試験形式）</h2>
        <p class="section-desc">文字式で答える練習。期末試験はこの形式！</p>

        <div class="exam-problem">
          <div class="problem-header">
            <span class="problem-num">総合1</span>
            <span class="problem-topic">等速度と等加速度の追いつき問題</span>
          </div>
          <div class="problem-body">
            <p>自動車Aが一定の速度 <Math f="v_0" /> で走っている。Aが静止している自動車Bの横を通り過ぎた瞬間（<Math f="t = 0" />）に、自動車Bは一定の加速度 <Math f="a" /> でAを追いかけ始めた。</p>
            <div class="problem-questions">
              <p><strong>(1)</strong> 時刻 <Math f="t" /> におけるAの変位 <Math f="x_A" /> とBの変位 <Math f="x_B" /> をそれぞれ式で表しなさい。</p>
              <p><strong>(2)</strong> BがAに追いつく時刻 <Math f="t_1" /> (<Math f="t_1 > 0" />) を <Math f="v_0, a" /> で表しなさい。</p>
            </div>
          </div>
          <details class="solution-details">
            <summary>💡 解答を見る</summary>
            <div class="solution-content">
              <p><strong>(1)</strong> Aは等速度運動：<Math f="x_A = v_0 t" /></p>
              <p class="indent">Bは初速度0の等加速度運動：<Math f="x_B = \\frac{1}{2} a t^2" /></p>
              <p><strong>(2)</strong> 追いつくとき <Math f="x_A = x_B" /> となるので、</p>
              <p class="indent"><Math f="v_0 t_1 = \\frac{1}{2} a t_1^2" /></p>
              <p class="indent"><Math f="t_1 \\neq 0" /> より、両辺を <Math f="t_1" /> で割ると <Math f="v_0 = \\frac{1}{2} a t_1" /></p>
              <p class="indent"><Math f="\\boxed{t_1 = \\frac{2v_0}{a}}" /></p>
            </div>
          </details>
        </div>
        
      </section>
    </div>
    </TabView>

  <div class="nav-buttons">
    <a href="/physics-basic/weeks/week10/" class="nav-btn secondary">← Week 10</a>
    <a href="/physics-basic/weeks/week12/" class="nav-btn">Week 12 へ →</a>
  </div>
</Layout>

<style>
  /* Base styles */
  .content-section {
    margin: 40px 0;
    padding: 24px;
    background: #ffffff;
    border-radius: 16px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  }

  .content-section h2 {
    color: #1e293b;
    font-size: 1.5rem;
    margin-bottom: 20px;
    padding-bottom: 12px;
    border-bottom: 3px solid #3b82f6;
  }

  .content-section h3 {
    margin-top: 32px;
    color: #334155;
    border-left: 4px solid #f59e0b;
    padding-left: 12px;
  }

  .intro-box {
    background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
    border-radius: 12px;
    padding: 20px;
    margin-bottom: 24px;
    font-size: 1.05rem;
  }

  .formula-box {
    background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
    border: 2px solid #3b82f6;
    border-radius: 12px;
    padding: 24px;
    text-align: center;
    margin: 24px 0;
  }

  .formula-box h4 {
    margin: 0 0 12px;
    color: #1d4ed8;
  }

  .big-formula {
    font-size: 1.5rem;
    font-weight: 700;
    color: #1d4ed8;
    display: block;
    margin: 8px 0;
    font-family: 'Courier New', monospace;
  }

  .exercise-section {
    background: #fafbfc;
  }

  .nav-buttons {
    display: flex;
    justify-content: space-between;
    margin-top: 40px;
    gap: 16px;
  }

  .nav-btn {
    flex: 1;
    display: inline-block;
    padding: 14px 24px;
    text-align: center;
    text-decoration: none;
    border-radius: 8px;
    font-weight: 600;
    transition: all 0.2s;
  }

  .nav-btn:not(.secondary) {
    background: #3b82f6;
    color: white;
  }

  .nav-btn:not(.secondary):hover {
    background: #2563eb;
  }

  .nav-btn.secondary {
    background: #f1f5f9;
    color: #475569;
  }

  .nav-btn.secondary:hover {
    background: #e2e8f0;
  }
</style>
