---
import Layout from '../../layouts/Layout.astro';
import QuizCard from '../../components/QuizCard.astro';
---

<Layout title="Week 5: 摩擦力">
  <h1>Week 5: 摩擦力</h1>

  <section class="content-section">
    <h2>🧊 静止摩擦力 vs 動摩擦力</h2>
    
    <div class="intro-box">
      摩擦力には <strong>2種類</strong> ある！ 物体が動いているかどうかで決まります。
    </div>

    <div class="incline-table">
      <table>
        <tr><th>種類</th><th>状態</th><th>特徴</th></tr>
        <tr>
          <td><strong>静止摩擦力</strong></td>
          <td>止まっている時</td>
          <td>引く力と同じ大きさで抵抗する（つり合い）</td>
        </tr>
        <tr>
          <td><strong>最大静止摩擦力</strong></td>
          <td>動き出す直前</td>
          <td>これ以上耐えられない限界の摩擦力</td>
        </tr>
        <tr>
          <td><strong>動摩擦力</strong></td>
          <td>動いている時</td>
          <td>常に一定の大きさ。最大静止摩擦力より少し小さい</td>
        </tr>
      </table>
    </div>

    <div class="formula-box">
      <h4>最大静止摩擦力</h4>
      <span class="big-formula">f_max = μN</span>
      <p>μ: 静止摩擦係数、N: 垂直抗力</p>
    </div>

    <div class="formula-box">
      <h4>動摩擦力</h4>
      <span class="big-formula">f' = μ'N</span>
      <p>μ': 動摩擦係数、N: 垂直抗力</p>
    </div>

    <div class="warning-box">
      <strong>⚠️ ポイント：</strong><br/>
      摩擦力は「面を押し付ける力（垂直抗力 N）」に比例します！重さ mg ではありません（斜面の場合は N = mg cosθ になるので注意）。
    </div>
  </section>

  <!-- ===== 練習セクション ===== -->
  <section class="content-section exercise-section">
    <h2>✏️ 練習問題：摩擦力</h2>

    <QuizCard 
      id="1"
      question="質量 2.0 kg の物体が水平面上に静止している。垂直抗力 N は？ (g = 9.8)"
      answer="19.6"
      answerUnit="N"
      steps={[
        "N = mg",
        "N = 2.0 × 9.8 = 19.6 N"
      ]}
    />

    <QuizCard 
      id="2"
      question="問1の物体を 5.0 N の力で水平に引いたが、動かなかった。このときの静止摩擦力は？"
      answer="5.0"
      answerUnit="N"
      steps={[
        "動かない＝力がつり合っている",
        "静止摩擦力 = 引く力 = 5.0 N"
      ]}
    />

    <QuizCard 
      id="3"
      question="問1の物体に働く最大静止摩擦力 f_max は？ (静止摩擦係数 μ = 0.50)"
      answer="9.8"
      answerUnit="N"
      steps={[
        "f_max = μN",
        "= 0.50 × 19.6 = 9.8 N"
      ]}
    />

    <QuizCard 
      id="4"
      question="問1の物体を 10 N の力で引いた。物体は動くか？ (ヒント: f_max は 9.8 N)"
      answer="動く"
      answerUnit=""
      steps={[
        "引く力 (10 N) > 最大静止摩擦力 (9.8 N)",
        "限界を超えたので動く。"
      ]}
    />

    <QuizCard 
      id="5"
      question="動いている物体の動摩擦力 f' は？ (動摩擦係数 μ' = 0.40、垂直抗力 N = 19.6 N)"
      answer="7.84"
      answerUnit="N"
      steps={[
        "f' = μ'N",
        "= 0.40 × 19.6 = 7.84 N"
      ]}
    />

    <QuizCard 
      id="6"
      question="質量 5.0 kg の物体を水平面上に置いた。垂直抗力 N は？ (g = 9.8)"
      answer="49"
      answerUnit="N"
      steps={[
        "N = mg = 5.0 × 9.8 = 49 N"
      ]}
    />

    <QuizCard 
      id="7"
      question="問6の物体が動き出す直前の引く力は何 N？ (μ = 0.60)"
      answer="29.4"
      answerUnit="N"
      steps={[
        "動き出す直前 ＝ 最大静止摩擦力",
        "f_max = μN = 0.60 × 49 = 29.4 N"
      ]}
    />

    <QuizCard 
      id="8"
      question="問6の物体が動いているときの摩擦力は何 N？ (μ' = 0.50)"
      answer="24.5"
      answerUnit="N"
      steps={[
        "動摩擦力 f' = μ'N",
        "= 0.50 × 49 = 24.5 N"
      ]}
    />

    <QuizCard 
      id="9"
      question="傾角 30° の斜面上にある質量 2.0 kg の物体の垂直抗力 N は？ (g = 9.8, cos30° ≈ 0.87)"
      answer="17.05"
      answerUnit="N"
      steps={[
        "N = mg cos30°",
        "= 2.0 × 9.8 × 0.87",
        "= 19.6 × 0.87 ≈ 17.05 N"
      ]}
    />

    <QuizCard 
      id="10"
      question="問9の物体に働く動摩擦力 f' は？ (μ' = 0.20)"
      answer="3.41"
      answerUnit="N"
      steps={[
        "f' = μ'N",
        "= 0.20 × 17.05 = 3.41 N"
      ]}
    />

  </section>

  <!-- ===== まとめ ===== -->
  <section class="content-section summary-section">
    <h2>📝 今日のまとめ</h2>
    <div class="summary-grid">
      <div class="summary-item">
        <span class="summary-icon">🛑</span>
        <span>静止摩擦力：<strong>引く力と同じ</strong>（動かない間）</span>
      </div>
      <div class="summary-item">
        <span class="summary-icon">⚠️</span>
        <span>最大静止摩擦力：<strong>f_max = μN</strong></span>
      </div>
      <div class="summary-item">
        <span class="summary-icon">🏃</span>
        <span>動摩擦力：<strong>f' = μ'N</strong>（動いている時）</span>
      </div>
    </div>
  </section>

  <div class="nav-buttons">
    <a href="/physics-basic/weeks/week04/" class="nav-btn secondary">← Week 4</a>
    <a href="/physics-basic/weeks/week06/" class="nav-btn">Week 6 へ →</a>
  </div>
</Layout>

<style>
  /* Reuse styles from week04 */
  .content-section { margin: 40px 0; padding: 24px; background: #ffffff; border-radius: 16px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
  .content-section h2 { color: #1e293b; font-size: 1.5rem; margin-bottom: 20px; padding-bottom: 12px; border-bottom: 3px solid #3b82f6; }
  .intro-box { background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%); border-radius: 12px; padding: 20px; margin-bottom: 24px; font-size: 1.05rem; }
  .formula-box { background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%); border: 2px solid #3b82f6; border-radius: 12px; padding: 24px; text-align: center; margin: 24px 0; }
  .formula-box h4 { margin: 0 0 12px; color: #1d4ed8; }
  .big-formula { font-size: 1.5rem; font-weight: 700; color: #1d4ed8; display: block; margin: 8px 0; font-family: 'Courier New', monospace; }
  .formula-box p { margin: 8px 0 0; color: #475569; }
  .incline-table table { width: 100%; border-collapse: collapse; margin: 16px 0; }
  .incline-table th, .incline-table td { padding: 12px; border: 1px solid #e2e8f0; text-align: center; }
  .incline-table th { background: #f1f5f9; }
  .warning-box { background: #fef2f2; border: 2px solid #ef4444; border-radius: 12px; padding: 16px 20px; margin: 20px 0; color: #991b1b; }
  .exercise-section { background: #fafbfc; }
  .summary-section { background: linear-gradient(135deg, #ecfdf5 0%, #d1fae5 100%); border: 2px solid #10b981; }
  .summary-section h2 { border-color: #10b981; color: #059669; }
  .summary-grid { display: grid; gap: 12px; }
  .summary-item { display: flex; align-items: center; gap: 12px; font-size: 1rem; }
  .summary-icon { font-size: 1.3rem; }
  .nav-buttons { display: flex; justify-content: space-between; margin-top: 40px; gap: 16px; }
  .nav-btn { flex: 1; display: inline-block; padding: 14px 24px; text-align: center; text-decoration: none; border-radius: 8px; font-weight: 600; transition: all 0.2s; }
  .nav-btn:not(.secondary) { background: #3b82f6; color: white; }
  .nav-btn:not(.secondary):hover { background: #2563eb; }
  .nav-btn.secondary { background: #f1f5f9; color: #475569; }
  .nav-btn.secondary:hover { background: #e2e8f0; }
</style>
