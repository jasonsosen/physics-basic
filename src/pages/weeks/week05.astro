      answerUnit="N"
      steps={[
        "斜面上の垂直抗力：N = mg cos θ",
        "N = 1.0 × 10 × cos 30°",
        "N = 10 × (√3/2) ≈ 8.66 N"
      ]}
    />

    <QuizCard 
      id="12"
      question="② 傾き θ = 30° のときの摩擦力 f を求めよ"
      answer="5.0"
      answerUnit="N"
      steps={[
        "滑り出す直前なので、摩擦力は斜面方向の重力成分とつりあいます。",
        "f = mg sin θ",
        "f = 1.0 × 10 × sin 30°",
        "f = 10 × 0.5 = 5.0 N"
      ]}
    />

    <QuizCard 
